import os
import json
import time
import subprocess

SEEN_IDS_FILE = os.path.expanduser("~/spamshield_test_final/spamshield_release/data/seen_ids.json")
os.makedirs(os.path.dirname(SEEN_IDS_FILE), exist_ok=True)

SMS_LIMIT = 5
SMS_TIMEOUT = 30
POLL_INTERVAL = 10

def load_seen_ids():
    if not os.path.exists(SEEN_IDS_FILE):
        return set()
    try:
        with open(SEEN_IDS_FILE, "r", encoding="utf-8") as f:
            data = json.load(f)
        return set(str(x) for x in data) if isinstance(data, list) else set()
    except Exception:
        return set()

def save_seen_ids(seen_ids):
    with open(SEEN_IDS_FILE, "w", encoding="utf-8") as f:
        json.dump(sorted(list(seen_ids)), f, ensure_ascii=False, indent=2)

def get_sms_list(limit=SMS_LIMIT):
    commands = [
        ["termux-sms-list", "-t", "inbox", "-l", str(limit)],
        ["termux-sms-list", "-l", str(limit)],
    ]

    for cmd in commands:
        try:
            print("Çalıştırılıyor:", " ".join(cmd), flush=True)
            result = subprocess.run(
                cmd,
                capture_output=True,
                text=True,
                timeout=SMS_TIMEOUT
            )

            print("Return code:", result.returncode, flush=True)

            if result.returncode != 0:
                print("STDERR:", result.stderr.strip(), flush=True)
                continue

            raw = (result.stdout or "").strip()
            print("Çıktı uzunluğu:", len(raw), flush=True)

            if not raw:
                return []

            data = json.loads(raw)
            if isinstance(data, list):
                return data

        except subprocess.TimeoutExpired:
            print("[HATA] termux-sms-list zaman aşımına uğradı.", flush=True)
        except json.JSONDecodeError:
            print("[HATA] JSON parse edilemedi.", flush=True)
        except Exception as e:
            print("SMS okuma hatası:", e, flush=True)

    return []

def analyze_message(body):
    body = (body or "").lower()
    score = 0
    spam_words = [
        "bonus", "freebet", "casino", "bahis", "kredi", "kampanya",
        "bit.ly", "hemen başvur", "tanitim iptali", "hoşgeldin bonusu"
    ]
    for w in spam_words:
        if w in body:
            score += 20
    if "http://" in body or "https://" in body:
        score += 30
    return "SPAM" if score >= 40 else "TEMIZ", score

def main():
    seen_ids = load_seen_ids()
    print("📡 SpamShield debug daemon başlatıldı...", flush=True)
    print("Yüklü seen_ids:", len(seen_ids), flush=True)

    while True:
        messages = get_sms_list(SMS_LIMIT)
        print("Okunan SMS sayısı:", len(messages), flush=True)

        for sms in messages:
            sms_id = str(sms.get("_id", ""))
            sender = sms.get("number") or sms.get("address") or "Bilinmiyor"
            body = sms.get("body", "")
            received = sms.get("received", "")

            print("-" * 60, flush=True)
            print("ID      :", sms_id, flush=True)
            print("Gönderen:", sender, flush=True)
            print("Tarih   :", received, flush=True)

            if sms_id in seen_ids:
                print("Durum   : ZATEN GÖRÜLDÜ", flush=True)
                continue

            seen_ids.add(sms_id)
            status, score = analyze_message(body)
            print("Durum   :", status, flush=True)
            print("Skor    :", score, flush=True)
            print("Mesaj   :", body[:250], flush=True)

        save_seen_ids(seen_ids)
        print("10 sn bekleniyor...\n", flush=True)
        time.sleep(POLL_INTERVAL)

if __name__ == "__main__":
    main()
