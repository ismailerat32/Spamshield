import json
import os
import re

AI_FILE = "data/ai_memory.json"


def clean_text(text):
    text = str(text).lower()
    text = re.sub(r"http[s]?://\\S+", "", text)  # link temizle
    text = re.sub(r"[^a-z0-9ğüşöçıİĞÜŞÖÇ ]", "", text)  # özel karakter sil
    return text


def similarity(a, b):
    a_words = set(a.split())
    b_words = set(b.split())

    if not a_words or not b_words:
        return 0

    ortak = len(a_words & b_words)
    toplam = len(a_words | b_words)

    return ortak / toplam


def load_ai():
    if not os.path.exists(AI_FILE):
        return {"spam": [], "clean": []}
    try:
        with open(AI_FILE, "r", encoding="utf-8") as f:
            return json.load(f)
    except:
        return {"spam": [], "clean": []}


def save_ai(data):
    with open(AI_FILE, "w", encoding="utf-8") as f:
        json.dump(data, f, indent=2, ensure_ascii=False)


def learn(message, label):
    data = load_ai()

    msg = clean_text(message)

    if label == "spam":
        data["spam"].append(msg)
    else:
        data["clean"].append(msg)

    save_ai(data)


def predict(message):
    data = load_ai()
    msg = clean_text(message)

    spam_score = 0
    clean_score = 0

    for m in data["spam"]:
        if similarity(msg, m) > 0.5:
            spam_score += 1

    for m in data["clean"]:
        if similarity(msg, m) > 0.5:
            clean_score += 1

    if clean_score > spam_score:
        return "TEMIZ_AI"

    if spam_score > clean_score:
        return "SPAM_AI"

    return "UNKNOWN"
