<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SpamShield Admin</title>
  <style>
    :root{
      --bg1:#020b18;
      --bg2:#05162d;
      --panel:rgba(14,30,56,.88);
      --line:rgba(255,255,255,.07);
      --text:#f8fbff;
      --muted:#9db5df;
      --blue:#4d8dff;
      --blue2:#78a9ff;
      --purple:#a066ff;
      --yellow:#ffd34f;
      --green:#1db56e;
      --red:#e85a4f;
      --orange:#f59e0b;
      --shadow:0 22px 60px rgba(0,0,0,.34);
      --shadow-soft:0 12px 28px rgba(0,0,0,.24);
    }

    *{box-sizing:border-box}
    html,body{min-height:100%}

    body{
      margin:0;
      color:var(--text);
      font-family:Inter, Arial, sans-serif;
      background:
        radial-gradient(circle at 12% 10%, rgba(77,141,255,.14), transparent 26%),
        radial-gradient(circle at 88% 14%, rgba(160,102,255,.12), transparent 24%),
        radial-gradient(circle at 50% 100%, rgba(40,110,255,.08), transparent 36%),
        linear-gradient(180deg, var(--bg1), var(--bg2) 56%, #041224);
      padding:22px 15px 42px;
    }

    body::before{
      content:"";
      position:fixed;
      inset:0;
      pointer-events:none;
      background:
        linear-gradient(rgba(255,255,255,.018), rgba(255,255,255,0)),
        repeating-linear-gradient(
          180deg,
          rgba(255,255,255,.012) 0px,
          rgba(255,255,255,.012) 1px,
          transparent 1px,
          transparent 26px
        );
      opacity:.28;
    }

    .topbar{
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      gap:14px;
      margin-bottom:20px;
    }

    .brand{
      display:flex;
      align-items:flex-start;
      gap:14px;
    }

    .brand .logo{
      width:58px;
      height:58px;
      display:flex;
      align-items:center;
      justify-content:center;
      font-size:42px;
      border-radius:18px;
      background:linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,.03));
      border:1px solid rgba(255,255,255,.08);
      box-shadow:var(--shadow-soft);
    }

    .brand h1{
      margin:0;
      font-size:31px;
      line-height:.95;
      font-weight:900;
      letter-spacing:-1px;
      text-shadow:0 8px 24px rgba(0,0,0,.28);
    }

    .back-link{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:10px 12px;
      border-radius:15px;
      text-decoration:none;
      color:var(--blue2);
      font-weight:800;
      font-size:16px;
      background:rgba(255,255,255,.03);
      border:1px solid rgba(255,255,255,.05);
      box-shadow:var(--shadow-soft);
    }

    .main-card{
      position:relative;
      background:linear-gradient(180deg, rgba(17,36,67,.90), rgba(12,28,53,.92));
      border:1px solid var(--line);
      border-radius:30px;
      padding:18px;
      box-shadow:var(--shadow);
      overflow:hidden;
    }

    .main-card::before{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background:
        linear-gradient(135deg, rgba(255,255,255,.05), transparent 30%),
        linear-gradient(180deg, rgba(77,141,255,.05), transparent 45%);
    }

    .main-title{
      position:relative;
      z-index:1;
      display:flex;
      align-items:center;
      gap:12px;
      margin:4px 4px 16px;
      font-size:23px;
      font-weight:900;
      letter-spacing:-.4px;
    }

    .main-title::before{
      content:"⚙️";
      font-size:26px;
    }

    .stats-grid{
      display:grid;
      grid-template-columns:repeat(2, minmax(0,1fr));
      gap:12px;
      margin:0 4px 16px;
      position:relative;
      z-index:1;
    }

    .stat-card{
      background:linear-gradient(180deg, rgba(255,255,255,.04), rgba(255,255,255,.022));
      border:1px solid rgba(255,255,255,.06);
      border-radius:18px;
      padding:14px 14px;
      box-shadow:var(--shadow-soft);
    }

    .stat-label{
      font-size:12px;
      color:var(--muted);
      margin-bottom:6px;
      font-weight:700;
    }

    .stat-value{
      font-size:24px;
      font-weight:900;
      letter-spacing:-.8px;
    }

    .section{
      position:relative;
      background:linear-gradient(180deg, rgba(255,255,255,.028), rgba(255,255,255,.018));
      border:1px solid rgba(255,255,255,.055);
      border-radius:24px;
      margin-bottom:14px;
      overflow:hidden;
      box-shadow:inset 0 1px 0 rgba(255,255,255,.03);
      transition:transform .25s ease, box-shadow .25s ease, border-color .25s ease;
    }

    .section.active{
      border-color:rgba(100,150,255,.20);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,.05),
        0 18px 52px rgba(0,0,0,.28),
        0 0 34px rgba(73,123,255,.10);
    }

    .section-toggle{
      width:100%;
      border:0;
      background:transparent;
      color:var(--text);
      text-align:left;
      padding:20px 18px;
      font-size:18px;
      font-weight:850;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      cursor:pointer;
    }

    .section-toggle .left{
      display:flex;
      align-items:center;
      gap:12px;
    }

    .section-toggle .icon{
      font-size:28px;
      line-height:1;
    }

    .section-toggle .chev{
      width:34px;
      height:34px;
      border-radius:999px;
      display:flex;
      align-items:center;
      justify-content:center;
      background:rgba(255,255,255,.04);
      border:1px solid rgba(255,255,255,.06);
      transition:transform .25s ease, background .25s ease;
    }

    .section.active .section-toggle .chev{
      transform:rotate(180deg);
      background:rgba(77,141,255,.12);
    }

    .section-content{
      display:none;
      padding:0 18px 18px;
    }

    .section.active .section-content{
      display:block;
    }

    .card,
    .user-card{
      background:linear-gradient(180deg, rgba(255,255,255,.032), rgba(255,255,255,.022));
      border:1px solid rgba(255,255,255,.055);
      border-radius:22px;
      padding:18px;
      margin-top:14px;
      box-shadow:var(--shadow-soft);
    }

    .user-card.is-banned{
      border-color:rgba(232,90,79,.28);
      box-shadow:
        0 18px 36px rgba(0,0,0,.24),
        0 0 24px rgba(232,90,79,.08);
    }

    input, select, button{
      width:100%;
      border:none;
      border-radius:18px;
      padding:18px 16px;
      font-size:16px;
      margin-top:12px;
    }

    input, select{
      color:#fff;
      background:linear-gradient(180deg, rgba(34,52,90,.98), rgba(29,45,78,.98));
      border:1px solid rgba(255,255,255,.05);
      outline:none;
    }

    input::placeholder{
      color:rgba(220,230,255,.45);
    }

    button{
      cursor:pointer;
      font-weight:800;
      transition:transform .15s ease, opacity .15s ease;
    }

    button:active{
      transform:translateY(1px);
    }

    button.primary{
      background:linear-gradient(135deg, #3d6df2, #4d89ff);
      color:#fff;
      box-shadow:0 16px 28px rgba(50,90,220,.28);
    }

    .user-name{
      font-size:25px;
      font-weight:900;
      letter-spacing:-.8px;
      margin:0 0 12px;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
    }

    .mini-status{
      font-size:11px;
      font-weight:900;
      letter-spacing:.4px;
      padding:7px 10px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.08);
      background:rgba(255,255,255,.04);
    }

    .mini-status.banned{
      background:rgba(232,90,79,.14);
      border-color:rgba(232,90,79,.25);
      color:#ffd8d4;
    }

    .badges{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      margin-bottom:12px;
    }

    .badge{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      padding:10px 14px;
      border-radius:999px;
      font-weight:850;
      font-size:14px;
      border:1px solid rgba(255,255,255,.06);
    }

    .b-role{ background:linear-gradient(135deg, rgba(52,103,240,.90), rgba(64,117,255,.76)); }
    .b-license{ background:linear-gradient(135deg, rgba(149,73,201,.92), rgba(171,91,223,.78)); }
    .b-active{ background:linear-gradient(135deg, rgba(24,163,74,.94), rgba(31,185,96,.78)); }
    .b-banned{ background:linear-gradient(135deg, rgba(232,90,79,.94), rgba(215,73,53,.78)); }

    .meta{
      font-size:15px;
      color:#d9e5ff;
      opacity:.92;
      margin:10px 0 0;
    }

    .license-box{
      margin-top:14px;
      background:linear-gradient(180deg, rgba(255,255,255,.032), rgba(255,255,255,.02));
      border:1px solid rgba(255,255,255,.05);
      border-radius:16px;
      padding:16px;
      font-size:15px;
      font-weight:850;
      word-break:break-word;
      cursor:pointer;
      user-select:none;
      -webkit-tap-highlight-color:transparent;
    }

    .license-box:active{
      transform:scale(.99);
    }

    .row-actions{
      display:flex;
      gap:12px;
      margin-top:14px;
      flex-wrap:wrap;
    }

    .row-actions form{
      flex:1 1 140px;
      margin:0;
    }

    .btn-small{
      width:100%;
      min-width:120px;
      padding:14px 18px;
      font-size:15px;
      font-weight:850;
      border-radius:16px;
      color:#fff;
      border:none;
    }

    .btn-purple{
      background:linear-gradient(135deg, #9b52d1, #b567e8);
      box-shadow:0 10px 22px rgba(155,82,209,.22);
    }

    .btn-red{
      background:linear-gradient(135deg, #d54935, #e65b46);
      box-shadow:0 10px 22px rgba(213,73,53,.22);
    }

    .btn-green{
      background:linear-gradient(135deg, #16a34a, #22c55e);
      box-shadow:0 10px 22px rgba(34,197,94,.22);
    }

    .btn-disabled{
      background:linear-gradient(135deg, #475569, #64748b);
      box-shadow:none;
      opacity:.78;
      cursor:not-allowed;
    }

    .is-loading{
      opacity:.82;
      pointer-events:none;
    }

    .empty-note{
      opacity:.78;
      font-size:14px;
      color:var(--muted);
      margin-top:10px;
    }

    .toast-top{
      position:fixed;
      top:20px;
      right:20px;
      background:rgba(15,23,42,0.95);
      color:#fff;
      padding:12px 18px;
      border-radius:14px;
      z-index:9999;
      font-weight:600;
      box-shadow:0 10px 30px rgba(0,0,0,0.4);
      opacity:0;
      transform:translateY(-10px);
      transition:all .3s ease;
    }

    .section.section-add .left{ color:#8d63ff; }
    .section.section-users .left{ color:#ffd34f; }
    .section.section-upgrades .left{ color:#ffffff; }

    @media (max-width:640px){
      body{ padding:20px 14px 40px; }
      .brand .logo{ width:52px; height:52px; font-size:38px; }
      .brand h1{ font-size:30px; }
      .back-link{ font-size:15px; padding:8px 10px; }
      .main-card{ border-radius:28px; padding:16px; }
      .main-title{ font-size:21px; }
      .section-toggle{ font-size:17px; padding:18px 16px; }
      .card,.user-card{ padding:16px; }
      .user-name{ font-size:23px; }
      .stats-grid{ grid-template-columns:repeat(2, minmax(0,1fr)); }
      .stat-value{ font-size:22px; }
      .toast-top{
        top:16px;
        right:16px;
        padding:10px 14px;
        font-size:12px;
      }
    }
  </style>

<style id="real-premium-admin-fix">
/* ===== SECTION HEADERS ===== */
.section-toggle{
  background: linear-gradient(180deg, rgba(25,42,79,.92), rgba(18,31,59,.98)) !important;
  border: 1px solid rgba(255,255,255,.06) !important;
  border-radius: 28px !important;
  box-shadow:
    0 16px 34px rgba(0,0,0,.18),
    inset 0 1px 0 rgba(255,255,255,.04);
  min-height: 96px;
}

.section-toggle .left span:last-child{
  font-size: 20px !important;
  font-weight: 900 !important;
  letter-spacing: -.3px;
}

.section-toggle .icon{
  font-size: 34px !important;
}

.section-toggle .chev{
  width: 62px;
  height: 62px;
  border-radius: 50%;
  display:flex;
  align-items:center;
  justify-content:center;
  background: linear-gradient(180deg, rgba(42,63,110,.65), rgba(29,45,84,.92));
  border: 1px solid rgba(255,255,255,.06);
  box-shadow: inset 0 1px 0 rgba(255,255,255,.03);
}

/* ===== MAIN STATS ===== */
.stat-card{
  background: linear-gradient(180deg, rgba(28,44,82,.92), rgba(18,31,59,.98)) !important;
  border: 1px solid rgba(255,255,255,.06) !important;
  border-radius: 26px !important;
  box-shadow:
    0 14px 28px rgba(0,0,0,.16),
    inset 0 1px 0 rgba(255,255,255,.03);
}

.stat-label{
  color: #aebee1 !important;
  font-weight: 700 !important;
}

.stat-value{
  color: #f5f8ff !important;
  font-size: 28px !important;
  font-weight: 900 !important;
}

/* ===== USER CARDS ===== */
.user-card{
  background: linear-gradient(180deg, rgba(23,38,74,.96), rgba(15,27,55,.99)) !important;
  border: 1px solid rgba(255,255,255,.06) !important;
  border-radius: 30px !important;
  box-shadow:
    0 24px 50px rgba(0,0,0,.24),
    inset 0 1px 0 rgba(255,255,255,.04);
  padding: 22px !important;
  margin-bottom: 26px !important;
  position: relative;
  overflow: hidden;
}

.user-card::before{
  content:"";
  position:absolute;
  inset:0;
  background: radial-gradient(circle at top, rgba(100,150,255,.08), transparent 58%);
  pointer-events:none;
}

.user-name{
  color: #f6f9ff !important;
  font-size: 26px !important;
  font-weight: 900 !important;
  letter-spacing: -.4px;
}

/* ===== SMALL STATUS ===== */
.mini-status{
  background: linear-gradient(180deg, rgba(53,71,112,.82), rgba(36,49,84,.96)) !important;
  color: #eef4ff !important;
  border: 1px solid rgba(255,255,255,.07) !important;
  border-radius: 999px !important;
  padding: 10px 16px !important;
  font-size: 13px !important;
  font-weight: 900 !important;
  box-shadow: 0 10px 24px rgba(0,0,0,.14);
}

.mini-status.banned{
  background: linear-gradient(135deg, #81454f, #b45569) !important;
  color: #fff !important;
}

/* ===== BADGES ===== */
.badge{
  border: none !important;
  border-radius: 999px !important;
  padding: 14px 24px !important;
  font-size: 14px !important;
  font-weight: 900 !important;
  letter-spacing: -.2px !important;
  box-shadow: 0 12px 24px rgba(0,0,0,.20);
}

.role-badge{
  background: linear-gradient(135deg, #4278ff, #5a96ff) !important;
  color: #fff !important;
}

.license-badge{
  background: linear-gradient(135deg, #9955ef, #c56aff) !important;
  color: #fff !important;
}

.state-badge.b-active,
.b-active{
  background: linear-gradient(135deg, #19b768, #2ede82) !important;
  color: #fff !important;
  box-shadow: 0 0 18px rgba(46,222,130,.20);
}

.state-badge.b-banned,
.b-banned{
  background: linear-gradient(135deg, #8d4650, #d15a72) !important;
  color: #fff !important;
}

/* ===== META ===== */
.meta,
.expiry-text{
  color: #d2dcf0 !important;
  font-size: 15px !important;
}

/* ===== LICENSE BOX ===== */
.license-box{
  background: linear-gradient(180deg, rgba(255,255,255,.03), rgba(255,255,255,.02)) !important;
  border: 1px solid rgba(255,255,255,.06) !important;
  border-radius: 22px !important;
  padding: 18px 18px !important;
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,.03),
    0 10px 20px rgba(0,0,0,.10);
}

.license-key-text{
  color: #f5f8ff !important;
  font-weight: 800 !important;
  line-height: 1.3 !important;
}

/* ===== FORM ELEMENTS ===== */
.normal-update-form{
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.normal-update-form input,
.normal-update-form select,
#addUserForm input,
#addUserForm select{
  background: linear-gradient(180deg, rgba(35,55,101,.95), rgba(24,40,78,.98)) !important;
  color: #f5f8ff !important;
  border: 1px solid rgba(255,255,255,.07) !important;
  border-radius: 24px !important;
  min-height: 72px !important;
  padding: 18px 22px !important;
  font-size: 18px !important;
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,.04),
    0 12px 24px rgba(0,0,0,.16);
}

.normal-update-form input:focus,
.normal-update-form select:focus,
#addUserForm input:focus,
#addUserForm select:focus{
  outline: none !important;
  border-color: rgba(106,166,255,.72) !important;
  box-shadow:
    0 0 0 4px rgba(95,147,255,.12),
    0 16px 30px rgba(0,0,0,.16);
}

/* ===== BUTTONS ===== */
.action-update-btn,
.action-generate-btn,
.action-ban-btn,
#addUserForm button.primary{
  min-height: 72px !important;
  border: none !important;
  border-radius: 26px !important;
  font-size: 20px !important;
  font-weight: 900 !important;
  letter-spacing: -.2px !important;
  transition: transform .15s ease, box-shadow .15s ease, opacity .15s ease;
  box-shadow: 0 18px 34px rgba(0,0,0,.22);
}

.action-update-btn{
  background: linear-gradient(135deg, #4b7eff, #6aa0ff) !important;
  color: #fff !important;
  box-shadow: 0 18px 34px rgba(76,126,255,.30) !important;
}

.action-generate-btn.btn-purple{
  background: linear-gradient(135deg, #9857ee, #c56dff) !important;
  color: #fff !important;
  box-shadow: 0 18px 34px rgba(152,87,238,.28) !important;
}

.action-generate-btn.btn-disabled{
  background: linear-gradient(135deg, #46536d, #5b6880) !important;
  color: #d4dbe8 !important;
  box-shadow: none !important;
  opacity: .82 !important;
}

.action-ban-btn.btn-red{
  background: linear-gradient(135deg, #e14c3e, #f26d57) !important;
  color: #fff !important;
  box-shadow: 0 18px 34px rgba(225,76,62,.26) !important;
}

.action-ban-btn.btn-green{
  background: linear-gradient(135deg, #18b768, #2ede82) !important;
  color: #fff !important;
  box-shadow: 0 18px 34px rgba(24,183,104,.24) !important;
}

.action-update-btn:active,
.action-generate-btn:active,
.action-ban-btn:active,
#addUserForm button.primary:active{
  transform: scale(.986);
}

/* ===== ROW ACTIONS ===== */
.row-actions{
  display: flex;
  flex-direction: column;
  gap: 14px;
  margin-top: 14px;
}

/* ===== MAIN CARD ===== */
.main-card{
  background: linear-gradient(180deg, rgba(25,43,79,.86), rgba(16,29,57,.96)) !important;
  border: 1px solid rgba(255,255,255,.06) !important;
  border-radius: 34px !important;
  box-shadow:
    0 24px 54px rgba(0,0,0,.22),
    inset 0 1px 0 rgba(255,255,255,.03);
}

.main-title{
  color: #f6f9ff !important;
  font-weight: 900 !important;
  letter-spacing: -.4px;
}

/* ===== EMPTY NOTE ===== */
.empty-note{
  color: #b7c4de !important;
  background: linear-gradient(180deg, rgba(255,255,255,.03), rgba(255,255,255,.015));
  border: 1px solid rgba(255,255,255,.05);
  border-radius: 22px;
  padding: 18px;
}

/* ===== MOBILE ===== */
@media (max-width: 420px){
  .user-name{
    font-size: 22px !important;
  }

  .badge{
    font-size: 13px !important;
    padding: 12px 18px !important;
  }

  .action-update-btn,
  .action-generate-btn,
  .action-ban-btn,
  #addUserForm button.primary{
    min-height: 68px !important;
    font-size: 18px !important;
  }
}
</style>


<style id="admin-tabs-upgrade">
.admin-tabs{
  display:flex;
  gap:10px;
  margin:18px 0 22px;
  position:sticky;
  top:10px;
  z-index:30;
  padding:8px;
  border-radius:22px;
  background:linear-gradient(180deg, rgba(14,24,48,.88), rgba(10,18,38,.94));
  border:1px solid rgba(255,255,255,.06);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  box-shadow:0 14px 28px rgba(0,0,0,.18);
}

.admin-tab-btn{
  flex:1;
  min-height:52px;
  border:none;
  border-radius:16px;
  font-size:15px;
  font-weight:900;
  color:#cfe0ff;
  background:linear-gradient(180deg, rgba(255,255,255,.04), rgba(255,255,255,.02));
  transition:all .16s ease;
}

.admin-tab-btn.active{
  color:#fff;
  background:linear-gradient(135deg,#4a7dff,#6aa3ff);
  box-shadow:0 12px 24px rgba(74,125,255,.24);
}

.section{
  margin-bottom:0 !important;
}

.section-toggle{
  display:none !important;
}

.section-content{
  display:none !important;
}

.section.active-tab .section-content{
  display:block !important;
}

.user-card{
  margin-bottom:18px !important;
}

.row-actions{
  gap:12px !important;
}

@media (max-width:420px){
  .admin-tabs{
    gap:8px;
    padding:6px;
  }
  .admin-tab-btn{
    min-height:48px;
    font-size:14px;
    padding:0 8px;
  }
}
</style>
































</head>
<body>

  <div class="topbar">
    <div class="brand">
      <div class="logo">🛡️</div>
      <h1>SpamShield<br>Admin</h1>
    </div>
    <a class="back-link" href="/dashboard">← Dashboard’a dön</a>
  </div>

  <div class="main-card">
    <div class="main-title">Kullanıcı ve Lisans İşlemleri</div>

    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-label">Toplam Kullanıcı</div>
        <div class="stat-value" id="statTotal">0</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Pro Lisans</div>
        <div class="stat-value" id="statPro">0</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Trial</div>
        <div class="stat-value" id="statTrial">0</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Banlı</div>
        <div class="stat-value" id="statBanned">0</div>
      </div>
    </div>

    <div class="section section-add">
      <button type="button" class="section-toggle">
        <div class="left">
          <span class="icon">👤</span>
          <span>Kullanıcı Ekle</span>
        </div>
        <div class="chev">˅</div>
      </button>
      <div class="section-content">
        <div class="card">
          <form method="POST" action="/admin/add-user" id="addUserForm">
            <input type="text" name="username" placeholder="Kullanıcı adı" required>
            <input type="password" name="password">
<input type="email" name="email" placeholder="Email adresi" required placeholder="Şifre" required>

            <select name="role">
              <option value="user">user</option>
              <option value="admin">admin</option>
            </select>

            <select name="license_type">
              <option value="trial">trial</option>
              <option value="pro">pro</option>
            </select>

            <input type="text" name="license_expiry" placeholder="Lisans bitişi (örn: 2099-01-01)">
            <button class="primary" type="submit">Kullanıcı Ekle</button>
          </form>
        </div>
      </div>
    </div>

    <div class="section section-users active">
      <button type="button" class="section-toggle">
        <div class="left">
          <span class="icon">📋</span>
          <span>Kullanıcılar</span>
        </div>
        <div class="chev">˅</div>
      </button>
      <div class="section-content">
        {% if users %}
          {% for row in users %}
            {% set has_valid_license = row.license_key and row.license_key[:4] == 'LIC-' %}
            <div class="user-card {% if row.is_banned %}is-banned{% endif %}"
                 id="user-{{ row.username }}"
                 data-username="{{ row.username }}"
                 data-role="{{ row.role if row.role else 'user' }}"
                 data-license-type="{{ row.license_type if row.license_type else 'trial' }}"
                 data-license-expiry="{{ row.license_expiry if row.license_expiry else '' }}"
                 data-license-key="{{ row.license_key if row.license_key else '' }}"
                 data-is-banned="{{ '1' if row.is_banned else '0' }}">
              <div class="user-name">
                <span>{{ row.username }}</span>
                <span class="mini-status {% if row.is_banned %}banned{% endif %}">
                  {% if row.is_banned %}BANLI{% else %}AKTİF{% endif %}
                </span>
              </div>

              <div class="badges">
                <span class="badge b-role role-badge">Rol: {{ row.role if row.role else 'user' }}</span>
                <span class="badge b-license license-badge">Lisans: {{ row.license_type if row.license_type else 'trial' }}</span>
                {% if row.is_banned %}
                  <span class="badge b-banned state-badge">BANLI</span>
                {% else %}
                  <span class="badge b-active state-badge">AKTİF</span>
                {% endif %}
              </div>

              <div class="meta expiry-text">Bitiş: {{ row.license_expiry if row.license_expiry else '-' }}</div>

              <div class="license-box" data-copy="{{ row.license_key if row.license_key else '' }}">
                Lisans Kodu:
                <span class="license-key-text">
                  {% if row.license_key %}{{ row.license_key }}{% else %}-{% endif %}
                </span>
              </div>

              <form method="POST" action="/admin/update-license/{{ row.username }}" class="normal-update-form">
                <input type="hidden" name="username" value="{{ row.username }}">

                <select name="license_type">
                  <option value="trial" {% if row.license_type == 'trial' %}selected{% endif %}>trial</option>
                  <option value="pro" {% if row.license_type == 'pro' %}selected{% endif %}>pro</option>
                </select>

                <input type="text" name="license_expiry" value="{{ row.license_expiry if row.license_expiry else '' }}" placeholder="YYYY-AA-GG">

                <button class="primary action-update-btn" type="submit">Lisans Güncelle</button>
              </form>

              <div class="row-actions">
                <form method="POST" action="/admin/generate-license/{{ row.username }}" class="ajax-form ajax-generate-form">
                  <input type="hidden" name="username" value="{{ row.username }}">
                  <button
                    class="btn-small action-generate-btn {% if has_valid_license %}btn-disabled{% else %}btn-purple{% endif %}"
                    type="submit"
                    {% if has_valid_license %}disabled{% endif %}>
                    {% if has_valid_license %}Zaten Var{% else %}Lisans Üret{% endif %}
                  </button>
                </form>

                <form method="POST" action="/admin/toggle-ban/{{ row.username }}" class="ajax-form ajax-ban-form">
                  <input type="hidden" name="username" value="{{ row.username }}">
                  <button
                    class="btn-small action-ban-btn {% if row.is_banned %}btn-green{% else %}btn-red{% endif %}"
                    type="submit">
                    {% if row.is_banned %}Ban Kaldır{% else %}Banla{% endif %}
                  </button>
                </form>
              </div>
            </div>
          {% endfor %}
        {% else %}
          <div class="empty-note">Henüz kullanıcı yok.</div>
        {% endif %}
      </div>
    </div>

    <div class="section section-upgrades">
      <button type="button" class="section-toggle">
        <div class="left">
          <span class="icon">⭐</span>
          <span>Yükseltme Talepleri</span>
        </div>
        <div class="chev">˅</div>
      </button>
      <div class="section-content">
        <div class="card">
          {% if upgrade_requests %}
            {% for req in upgrade_requests %}
              <div class="user-card">
                <div class="user-name">
                  <span>{{ req.username if req.username else 'Bilinmeyen Kullanıcı' }}</span>
                  <span class="mini-status">TALEP</span>
                </div>
                <div class="meta">Talep: {{ req.request_type if req.request_type else 'upgrade' }}</div>
                <div class="meta">Tarih: {{ req.created_at if req.created_at else '-' }}</div>
              </div>
            {% endfor %}
          {% else %}
            <div class="empty-note">Bekleyen yükseltme talebi yok.</div>
          {% endif %}
        </div>
      </div>
    </div>

  </div>

  <script>
    document.addEventListener("DOMContentLoaded", function () {
      const sections = document.querySelectorAll(".section");

      sections.forEach(function(section){
        const toggle = section.querySelector(".section-toggle");
        if (toggle) {
          toggle.addEventListener("click", function (e) {
            e.preventDefault();
            e.stopPropagation();
            section.classList.toggle("active");
          });
        }
      });

      function showTopToast(message){
        const old = document.getElementById("topToast");
        if (old) old.remove();

        const toast = document.createElement("div");
        toast.id = "topToast";
        toast.className = "toast-top";
        toast.textContent = message;
        document.body.appendChild(toast);

        requestAnimationFrame(function(){
          toast.style.opacity = "1";
          toast.style.transform = "translateY(0)";
        });

        setTimeout(function(){
          toast.style.opacity = "0";
          toast.style.transform = "translateY(-10px)";
          setTimeout(function(){ toast.remove(); }, 300);
        }, 1800);
      }

      async function copyText(text){
        if (!text || text === "-") {
          showTopToast("Kopyalanacak lisans yok");
          return;
        }
        try{
          if(navigator.clipboard && navigator.clipboard.writeText){
            await navigator.clipboard.writeText(text);
          }else{
            const ta = document.createElement("textarea");
            ta.value = text;
            document.body.appendChild(ta);
            ta.select();
            document.execCommand("copy");
            ta.remove();
          }
          showTopToast("Lisans kopyalandı");
        }catch(err){
          console.log("copy error:", err);
          showTopToast("Kopyalama başarısız");
        }
      }

      document.querySelectorAll(".license-box[data-copy]").forEach(function(el){
        el.addEventListener("click", function(e){
          e.preventDefault();
          e.stopPropagation();
          const text = (el.getAttribute("data-copy") || "").trim();
          copyText(text);
        });
      });

      function updateStats(){
        const cards = Array.from(document.querySelectorAll(".user-card[data-username]"));
        const total = cards.length;
        let pro = 0;
        let trial = 0;
        let banned = 0;

        cards.forEach(function(card){
          const t = card.dataset.licenseType || "trial";
          const isBanned = card.dataset.isBanned === "1";
          if (t === "pro") pro += 1;
          else trial += 1;
          if (isBanned) banned += 1;
        });

        const totalEl = document.getElementById("statTotal");
        const proEl = document.getElementById("statPro");
        const trialEl = document.getElementById("statTrial");
        const bannedEl = document.getElementById("statBanned");

        if (totalEl) totalEl.textContent = String(total);
        if (proEl) proEl.textContent = String(pro);
        if (trialEl) trialEl.textContent = String(trial);
        if (bannedEl) bannedEl.textContent = String(banned);
      }

      function setButtonLoading(btn, loadingText){
        if (!btn) return;
        btn.dataset.originalText = btn.textContent;
        btn.textContent = loadingText;
        btn.classList.add("is-loading");
        btn.disabled = true;
      }

      function restoreButton(btn){
        if (!btn) return;
        if (btn.dataset.originalText) btn.textContent = btn.dataset.originalText;
        btn.classList.remove("is-loading");
        btn.disabled = false;
      }

      async function submitAjaxForm(form, onSuccess){
        const btn = form.querySelector("button[type='submit']");
        const formData = new FormData(form);
        const loadingText = btn && btn.classList.contains("action-update-btn")
          ? "Güncelleniyor..."
          : btn && btn.classList.contains("action-generate-btn")
            ? "Üretiliyor..."
            : btn && btn.classList.contains("action-ban-btn")
              ? "İşleniyor..."
              : "Gönderiliyor...";

        setButtonLoading(btn, loadingText);

        try{
          const response = await fetch(form.action, {
            method: "POST",
            body: formData,
            credentials: "same-origin",
            redirect: "follow"
          });

          const finalUrl = new URL(response.url);
          const ok = finalUrl.searchParams.get("ok") || "";
          const licenseKey = finalUrl.searchParams.get("license_key") || "";

          if (typeof onSuccess === "function") {
            onSuccess({ ok, licenseKey, response, finalUrl });
          }
        }catch(err){
          console.log("ajax form error:", err);
          showTopToast("İşlem başarısız");
        }finally{
          restoreButton(btn);
        }
      }

            document.querySelectorAll(".ajax-generate-form").forEach(function(form){
        form.addEventListener("submit", function(e){
          e.preventDefault();
          e.stopPropagation();

          const card = form.closest(".user-card");
          submitAjaxForm(form, function(data){
            if (!card) return;

            let key = "";
            if (data.licenseKey) {
              key = data.licenseKey;
            } else {
              key = (card.dataset.licenseKey || "").trim();
            }

            if (key) {
              card.dataset.licenseKey = key;

              const licenseBox = card.querySelector(".license-box");
              const keyText = card.querySelector(".license-key-text");
              const genBtn = card.querySelector(".action-generate-btn");

              if (licenseBox) licenseBox.setAttribute("data-copy", key);
              if (keyText) keyText.textContent = key;

              if (genBtn) {
                genBtn.textContent = "Zaten Var";
                genBtn.disabled = true;
                genBtn.classList.remove("btn-purple");
                genBtn.classList.add("btn-disabled");
              }

              copyText(key);
              updateStats();
              if (data.ok === "license_exists") showTopToast("Lisans zaten var");
              else showTopToast("Lisans üretildi");
            } else {
              showTopToast("Lisans bilgisi alınamadı");
            }
          });
        });
      });

      document.querySelectorAll(".ajax-ban-form").forEach(function(form){
        form.addEventListener("submit", function(e){
          e.preventDefault();
          e.stopPropagation();

          const card = form.closest(".user-card");
          submitAjaxForm(form, function(){
            if (!card) return;

            const currentlyBanned = card.dataset.isBanned === "1";
            const nextBanned = !currentlyBanned;
            card.dataset.isBanned = nextBanned ? "1" : "0";

            const mini = card.querySelector(".mini-status");
            const stateBadge = card.querySelector(".state-badge");
            const banBtn = card.querySelector(".action-ban-btn");

            if (nextBanned) {
              card.classList.add("is-banned");
              if (mini) {
                mini.textContent = "BANLI";
                mini.classList.add("banned");
              }
              if (stateBadge) {
                stateBadge.textContent = "BANLI";
                stateBadge.classList.remove("b-active");
                stateBadge.classList.add("b-banned");
              }
              if (banBtn) {
                banBtn.textContent = "Ban Kaldır";
                banBtn.classList.remove("btn-red");
                banBtn.classList.add("btn-green");
              }
              showTopToast("Kullanıcı banlandı");
            } else {
              card.classList.remove("is-banned");
              if (mini) {
                mini.textContent = "AKTİF";
                mini.classList.remove("banned");
              }
              if (stateBadge) {
                stateBadge.textContent = "AKTİF";
                stateBadge.classList.remove("b-banned");
                stateBadge.classList.add("b-active");
              }
              if (banBtn) {
                banBtn.textContent = "Banla";
                banBtn.classList.remove("btn-green");
                banBtn.classList.add("btn-red");
              }
              showTopToast("Ban kaldırıldı");
            }

            updateStats();
          });
        });
      });

      updateStats();

      const params = new URLSearchParams(window.location.search);
      const openSection = params.get("open");
      if (openSection === "users") {
        const s = document.querySelector(".section-users");
        if (s) s.classList.add("active");
      } else if (openSection === "add") {
        const s = document.querySelector(".section-add");
        if (s) s.classList.add("active");
      } else if (openSection === "upgrades") {
        const s = document.querySelector(".section-upgrades");
        if (s) s.classList.add("active");
      }

      const ok = params.get("ok");
      if (ok === "license_generated") showTopToast("Lisans üretildi");
      else if (ok === "license_exists") showTopToast("Lisans zaten var");
      else if (ok === "license_updated") showTopToast("Lisans güncellendi");
      else if (ok === "ban_toggled") showTopToast("Kullanıcı durumu güncellendi");
      else if (ok === "upgrade_approved") showTopToast("Yükseltme onaylandı");
      else if (ok === "user_added") showTopToast("Kullanıcı eklendi");
      else if (ok === "user_exists") showTopToast("Bu kullanıcı zaten var");
      else if (ok === "missing_fields") showTopToast("Eksik alan var");
      else if (ok === "user_not_found") showTopToast("Kullanıcı bulunamadı");
      else if (ok === "done") showTopToast("İşlem tamamlandı");
    });
  </script>





<style id="toggle-fix">

.user-details{
  display:none !important;
}

.user-card.open .user-details{
  display:block !important;
}

</style>







<style id="safe-admin-recovery">
.admin-tabs{
  display:flex !important;
  gap:10px !important;
  margin:18px 0 18px 0 !important;
  padding:8px !important;
  background:rgba(5,12,35,.38) !important;
  border-radius:22px !important;
  box-shadow:inset 0 0 0 1px rgba(255,255,255,.04) !important;
}
.admin-tab-btn{
  flex:1 1 0 !important;
  min-height:68px !important;
  border:none !important;
  border-radius:20px !important;
  background:linear-gradient(180deg, rgba(18,28,66,.95), rgba(8,18,48,.92)) !important;
  color:#f3f7ff !important;
  font-size:17px !important;
  font-weight:800 !important;
  line-height:1.1 !important;
  padding:0 10px !important;
  box-shadow:0 10px 24px rgba(0,0,0,.18) !important;
}
.admin-tab-btn.active{
  background:linear-gradient(135deg,#4b7dff,#73a4ff) !important;
  color:#ffffff !important;
  box-shadow:0 10px 28px rgba(88,141,255,.34) !important;
}

.admin-tab-section{
  display:none !important;
}
.admin-tab-section.active{
  display:block !important;
}

.section-users,
.section-add,
.section-upgrades{
  display:block !important;
  margin-top:0 !important;
}

.section-users > .section-toggle,
.section-add > .section-toggle,
.section-upgrades > .section-toggle{
  display:none !important;
}

.section-users > .section-content,
.section-add > .section-content,
.section-upgrades > .section-content{
  display:block !important;
  padding:0 !important;
}

.section-users .user-card{
  display:block !important;
  margin-bottom:18px !important;
}

.section-users .user-summary{
  display:grid !important;
  grid-template-columns:minmax(0,1fr) auto !important;
  align-items:center !important;
  gap:12px !important;
  padding:16px !important;
}

.section-users .user-details{
  display:none !important;
  padding:0 16px 16px 16px !important;
}
.section-users .user-card.open .user-details{
  display:block !important;
}

.user-toggle-btn{
  display:flex !important;
  align-items:center !important;
  justify-content:center !important;
  width:54px !important;
  height:54px !important;
  border:none !important;
  border-radius:50% !important;
  background:linear-gradient(180deg, rgba(41,61,120,.92), rgba(28,46,95,.92)) !important;
  color:#fff !important;
  font-size:28px !important;
  font-weight:900 !important;
  box-shadow:0 10px 20px rgba(0,0,0,.18), inset 0 0 0 1px rgba(255,255,255,.05) !important;
}
.user-toggle-icon{
  display:inline-block !important;
  transform:translateY(-1px) rotate(0deg) !important;
  transition:transform .22s ease !important;
}
.user-card.open .user-toggle-icon{
  transform:translateY(-1px) rotate(180deg) !important;
}

@media (max-width:420px){
  .admin-tab-btn{
    min-height:64px !important;
    font-size:15px !important;
    padding:0 6px !important;
  }
}
</style>

<script id="safe-admin-recovery-js">
document.addEventListener("DOMContentLoaded", function () {
  const mainCard = document.querySelector(".main-card");
  const usersSec = document.querySelector(".section-users");
  const addSec = document.querySelector(".section-add");
  const upgradesSec = document.querySelector(".section-upgrades");
  if (!mainCard || !usersSec || !addSec || !upgradesSec) return;

  // Eski tab bar varsa kaldır
  const oldTabs = document.querySelector(".admin-tabs");
  if (oldTabs) oldTabs.remove();

  // Bölümleri tab-section olarak işaretle
  usersSec.classList.add("admin-tab-section");
  addSec.classList.add("admin-tab-section");
  upgradesSec.classList.add("admin-tab-section");

  // Yeni tab bar
  const tabs = document.createElement("div");
  tabs.className = "admin-tabs";
  tabs.innerHTML = `
    <button type="button" class="admin-tab-btn active" data-target="users">Kullanıcılar</button>
    <button type="button" class="admin-tab-btn" data-target="add">Kullanıcı Ekle</button>
    <button type="button" class="admin-tab-btn" data-target="upgrades">Talepler</button>
  `;

  // Stats grid'in altına yerleştir
  const statsGrid = mainCard.querySelector(".stats-grid");
  if (statsGrid && statsGrid.nextSibling) {
    mainCard.insertBefore(tabs, statsGrid.nextSibling);
  } else {
    mainCard.appendChild(tabs);
  }

  // Section toggle başlıklarını gizleyip sadece content bırak
  const map = {
    users: usersSec,
    add: addSec,
    upgrades: upgradesSec
  };

  function activate(name){
    Object.entries(map).forEach(([key, sec]) => {
      sec.classList.toggle("active", key === name);
    });
    tabs.querySelectorAll(".admin-tab-btn").forEach(btn => {
      btn.classList.toggle("active", btn.dataset.target === name);
    });
  }

  tabs.addEventListener("click", function(e){
    const btn = e.target.closest(".admin-tab-btn");
    if (!btn) return;
    activate(btn.dataset.target);
  });

  activate("users");

  // Kullanıcı kartlarında toggle butonu yoksa ekle
  document.querySelectorAll(".section-users .user-card").forEach(card => {
    let summary = card.querySelector(".user-summary");
    let details = card.querySelector(".user-details");

    if (!summary) {
      const firstMeta = Array.from(card.children).find(el => !el.classList.contains("user-details"));
      if (firstMeta) {
        summary = document.createElement("div");
        summary.className = "user-summary";
        while (card.firstChild && card.firstChild !== details) {
          summary.appendChild(card.firstChild);
        }
        card.insertBefore(summary, details || card.firstChild);
      }
    }

    if (!summary) return;

    let btn = summary.querySelector(".user-toggle-btn");
    if (!btn) {
      btn = document.createElement("button");
      btn.type = "button";
      btn.className = "user-toggle-btn";
      btn.innerHTML = '<span class="user-toggle-icon">⌄</span>';
      summary.appendChild(btn);
    }

    btn.addEventListener("click", function(ev){
      ev.preventDefault();
      ev.stopPropagation();
      card.classList.toggle("open");
    });
  });
});
</script>

</body>
</html>
