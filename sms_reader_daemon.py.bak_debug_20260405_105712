import os
import json
import time
import logging
import subprocess
from datetime import datetime

BASE_DIR = os.path.expanduser("~/spamshield")
DATA_DIR = os.path.join(BASE_DIR, "data")
LOG_DIR = os.path.join(BASE_DIR, "logs")

SEEN_IDS_FILE = os.path.join(DATA_DIR, "seen_ids.json")
LOG_FILE = os.path.join(LOG_DIR, "sms_daemon.log")

SMS_LIMIT = 20
SMS_TIMEOUT = 30
POLL_INTERVAL = 15

SPAM_WORDS = [
    "bonus", "freebet", "casino", "bahis", "kredi fırsatı",
    "hemen başvur", "kampanya", "bit.ly", "tinyurl", "tanitim iptali",
    "yatırım fırsatı", "deneme bonusu", "hoşgeldin bonusu", "faizsiz kredi"
]

os.makedirs(DATA_DIR, exist_ok=True)
os.makedirs(LOG_DIR, exist_ok=True)

logging.basicConfig(
    filename=LOG_FILE,
    level=logging.INFO,
    format="%(asctime)s - %(levelname)s - %(message)s",
)

def log_print(msg: str):
    print(msg, flush=True)
    logging.info(msg)

def load_seen_ids():
    if not os.path.exists(SEEN_IDS_FILE):
        return set()
    try:
        with open(SEEN_IDS_FILE, "r", encoding="utf-8") as f:
            data = json.load(f)
        if isinstance(data, list):
            return set(str(x) for x in data)
    except Exception:
        pass
    return set()

def save_seen_ids(seen_ids):
    try:
        with open(SEEN_IDS_FILE, "w", encoding="utf-8") as f:
            json.dump(sorted(list(seen_ids)), f, ensure_ascii=False, indent=2)
    except Exception as e:
        log_print(f"seen_ids kayıt hatası: {e}")

def get_sms_list(limit=SMS_LIMIT):
    commands = [
        ["termux-sms-list", "-t", "inbox", "-l", str(limit)],
        ["termux-sms-list", "-l", str(limit)],
    ]

    last_error = None

    for cmd in commands:
        try:
            result = subprocess.run(
                cmd,
                capture_output=True,
                text=True,
                timeout=SMS_TIMEOUT
            )

            if result.returncode != 0:
                last_error = f"komut hata verdi: {' '.join(cmd)} | {result.stderr.strip()}"
                continue

            raw = (result.stdout or "").strip()
            if not raw:
                return []

            data = json.loads(raw)
            if isinstance(data, list):
                return data

            last_error = f"beklenmeyen veri tipi: {type(data)}"
        except subprocess.TimeoutExpired:
            last_error = f"⚠️ termux-sms-list zaman aşımına uğradı. Komut: {' '.join(cmd)}"
        except json.JSONDecodeError:
            last_error = f"SMS çıktısı JSON değil. Komut: {' '.join(cmd)}"
        except Exception as e:
            last_error = f"termux-sms-list çalıştırma hatası: {e}"

    if last_error:
        log_print(last_error)

    return []

def analyze_message(sms):
    body = (sms.get("body") or "").lower()
    score = 0

    for word in SPAM_WORDS:
        if word in body:
            score += 20

    if "http://" in body or "https://" in body:
        score += 30

    if "iptal" in body and ("b001" in body or "b016" in body or "b043" in body):
        score += 10

    status = "SPAM" if score >= 40 else "TEMIZ"
    return status, score

def format_sender(sms):
    return sms.get("number") or sms.get("address") or "Bilinmiyor"

def main():
    seen_ids = load_seen_ids()
    log_print("📡 SpamShield daemon başlatıldı...")

    while True:
        messages = get_sms_list(SMS_LIMIT)

        if messages:
            for sms in messages:
                sms_id = str(sms.get("_id", ""))
                if not sms_id:
                    continue

                if sms_id in seen_ids:
                    continue

                seen_ids.add(sms_id)

                sender = format_sender(sms)
                body = sms.get("body", "")
                received = sms.get("received", "")
                status, score = analyze_message(sms)

                log_print("-" * 60)
                log_print(f"Gönderen : {sender}")
                log_print(f"Tarih    : {received}")
                log_print(f"Durum    : {status}")
                log_print(f"Skor     : {score}")
                log_print(f"Mesaj    : {body[:300]}")

            save_seen_ids(seen_ids)

        time.sleep(POLL_INTERVAL)

if __name__ == "__main__":
    main()
