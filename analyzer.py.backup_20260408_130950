import re
import json
import os
from ai_model import predict

WHITELIST_FILE = "data/whitelist.json"


def is_whitelisted_sender(sender):
    try:
        if not os.path.exists(WHITELIST_FILE):
            return False

        with open(WHITELIST_FILE, "r", encoding="utf-8") as f:
            whitelist = json.load(f)

        sender = str(sender).upper()

        return any(w in sender for w in whitelist)
    except:
        return False


SPAM_KEYWORDS = [
    "kazandın","ödül","bedava","tıkla","hemen","şimdi",
    "bonus","casino","bahis","freebet","promosyon",
    "kampanya","fırsat","linke gir","giriş yap"
]

DANGEROUS_DOMAINS = [
    "bit.ly","tinyurl","t.me","goo.gl"
]


def contains_link(text):
    return re.search(r"http[s]?://", text or "") is not None


def extract_links(text):
    return re.findall(r"http[s]?://\\S+", text or "")


def analyze_sms(sender, message):

    # 🔥 1. WHITELIST OVERRIDE (EN KRİTİK)
    if is_whitelisted_sender(sender):
        return {
            "status": "TEMIZ",
            "score": 0,
            "category": "WHITELIST",
            "reason": "WHITELIST_OVERRIDE"
        }

# 🤖 AI ANALİZİ
    ai_result = predict(message)

    if ai_result == "TEMIZ_AI":
        return {
            "status": "TEMIZ",
            "score": 0,
            "category": "AI",
            "reason": "AI_CLEAN"
        }

    if ai_result == "SPAM_AI":
        return {
            "status": "SPAM",
            "score": 80,
            "category": "AI",
            "reason": "AI_SPAM"
        }

    score = 0
    reasons = []
    msg = str(message or "").lower()

    # keyword
    for word in SPAM_KEYWORDS:
        if word in msg:
            score += 10
            reasons.append(word)

    # link
    if contains_link(msg):
        score += 15
        reasons.append("link")

    # domain
    for link in extract_links(msg):
        for d in DANGEROUS_DOMAINS:
            if d in link:
                score += 25
                reasons.append(d)

    # karar
    status = "SPAM" if score >= 30 else "TEMIZ"

    return {
        "status": status,
        "score": score,
        "category": "GENEL",
        "reason": " + ".join(reasons) if reasons else "CLEAN"
    }
