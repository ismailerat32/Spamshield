<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SpamShield Admin Panel</title>
<style>
*{box-sizing:border-box}
body{margin:0;background:#071224;color:#fff;font-family:Arial,sans-serif}
.wrap{max-width:1100px;margin:0 auto;padding:18px}
.topbar{display:flex;align-items:flex-start;justify-content:space-between;gap:12px;margin-bottom:18px}
.title{font-size:32px;font-weight:800;line-height:1.05}
.back{color:#9cc0ff;text-decoration:none;font-weight:700;font-size:15px}
.card{background:#14223a;border:1px solid rgba(255,255,255,0.05);border-radius:20px;padding:18px;margin-bottom:16px}
.card h3{margin:0 0 14px 0;font-size:22px}
.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
input,select,button{width:100%;padding:13px 14px;border-radius:14px;border:none;outline:none;font-size:15px}
input,select{background:#1e2b45;color:#fff}
button{background:#3169ea;color:#fff;font-weight:800;cursor:pointer}
button.red{background:#c0392b}
button.green{background:#159947}
button.purple{background:#8e44ad}
.user-card{background:#1a2740;border-radius:18px;padding:16px;margin-bottom:12px}
.username{font-size:20px;font-weight:800;margin-bottom:8px}
.badges{display:flex;gap:8px;flex-wrap:wrap;margin:8px 0 12px 0}
.badge{padding:6px 10px;border-radius:999px;font-size:12px;font-weight:800}
.badge.role{background:#2f67e8}
.badge.license{background:#8e44ad}
.badge.banned{background:#c0392b}
.badge.active{background:#159947}
.muted{color:#c8d5f0;font-size:14px;margin-bottom:12px}
.license-box{background:#1d2a42;border-radius:12px;padding:10px 12px;margin:10px 0 14px 0;font-weight:700;color:#f3f7ff;word-break:break-all}
.license-form{display:grid;grid-template-columns:1fr 1fr auto;gap:10px;margin-top:10px}
.actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:12px}
.single-form{margin:0}
@media (max-width:700px){
  .form-grid{grid-template-columns:1fr}
  .license-form{grid-template-columns:1fr}
  .title{font-size:26px}
}
</style>
</head>
<body>
<div class="wrap">
  <div class="topbar">
    <div class="title">🛡 SpamShield Admin</div>
    <a class="back" href="/dashboard">← Dashboard’a dön</a>
  </div>

  <div class="card">
    <h3>Kullanıcı Ekle</h3>
    <form method="POST" action="/admin/add-user">
      <div class="form-grid">
        <input type="text" name="username" placeholder="Kullanıcı adı" required>
        <input type="text" name="password" placeholder="Şifre" required>

        <select name="role">
          <option value="user">user</option>
          <option value="admin">admin</option>
        </select>

        <select name="license_type">
          <option value="trial">trial</option>
          <option value="pro">pro</option>
          <option value="free">free</option>
        </select>

        <input type="text" name="license_expiry" placeholder="Lisans bitişi (örn: 2099-01-01)">
        <button type="submit">Kullanıcı Ekle</button>
      </div>
    </form>
  </div>

  <div class="card">
    <h3>Yükseltme Talepleri</h3>

    {% if upgrade_requests %}
      {% for row in upgrade_requests %}
        {% if row.status == "pending" %}
        <div class="user-card">
          <div class="username">{{ row.username }}</div>
          <div class="muted">Mevcut Lisans: {{ row.current_license }}</div>

          <div class="actions">
            <form class="single-form" method="POST" action="/admin/approve-upgrade/{{ row.username }}">
              <button class="green" type="submit">PRO Olarak Onayla</button>
            </form>
          </div>
        </div>
        {% endif %}
      {% endfor %}
    {% else %}
      <div class="muted">Henüz talep yok.</div>
    {% endif %}
  </div>

  <div class="card">
    <h3>Kullanıcılar</h3>

    {% for user in users %}
    <div class="user-card" id="user-{{ user.username }}">
      <div class="username">{{ user.username }}</div>

      <div class="badges">
        <span class="badge role">Rol: {{ user.role }}</span>
        <span class="badge license">Lisans: {{ user.license_type }}</span>
        {% if user.is_banned %}
        <span class="badge banned">BANLI</span>
        {% else %}
        <span class="badge active">AKTİF</span>
        {% endif %}
      </div>

      <div class="muted">Bitiş: {{ user.license_expiry if user.license_expiry else "-" }}</div>

      <div class="license-box">
        Lisans Kodu: {{ user.license_key if user.license_key else "Henüz yok" }}
      </div>

      <form class="license-form" method="POST" action="/admin/update-license/{{ user.username }}">
        <select name="license_type">
          <option value="trial" {% if user.license_type == "trial" %}selected{% endif %}>trial</option>
          <option value="pro" {% if user.license_type == "pro" %}selected{% endif %}>pro</option>
          <option value="free" {% if user.license_type == "free" %}selected{% endif %}>free</option>
        </select>

        <input type="text" name="license_expiry" value="{{ user.license_expiry }}" placeholder="YYYY-MM-DD">

        <button type="submit">Lisans Güncelle</button>
      </form>

      <div class="actions">
        <form class="single-form" method="POST" action="/admin/generate-license/{{ user.username }}">
          <button class="purple" type="submit">Lisans Üret</button>
        </form>

        <form class="single-form" method="POST" action="/admin/toggle-ban/{{ user.username }}">
          {% if user.is_banned %}
          <button class="green" type="submit">Ban Kaldır</button>
          {% else %}
          <button class="red" type="submit">Banla</button>
          {% endif %}
        </form>
      </div>
    </div>
    {% else %}
    <div class="muted">Henüz kullanıcı yok.</div>
    {% endfor %}
  </div>
</div>
</body>
</html>
