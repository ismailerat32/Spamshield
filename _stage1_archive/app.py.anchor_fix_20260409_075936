        if not username:
            return render_template(
                "admin_licenses.html",
                users=users,
                licenses=licenses,
                error="Kullanıcı adı gerekli"
            )

        if username not in users:
            return render_template(
                "admin_licenses.html",
                users=users,
                licenses=licenses,
                error="Kullanıcı bulunamadı"
            )

        try:
            duration_days = int(duration_days_raw)
        except Exception:
            duration_days = 30

        if duration_days < 1:
            duration_days = 1

        from datetime import datetime, timedelta

        license_key = generate_license_key()
        created_at = datetime.utcnow().strftime("%Y-%m-%d")
        expires_at = (datetime.utcnow() + timedelta(days=duration_days)).strftime("%Y-%m-%d")

        licenses[license_key] = {
            "username": username,
            "username": username,
            "plan": plan,
            "status": "active",
            "created_at": created_at,
            "expires_at": expires_at
        }
        save_licenses(licenses)
        sync_user_license(username, license_key, plan, expires_at)

        users = load_users()
        licenses = load_licenses()

        return render_template(
            "admin_licenses.html",
            users=users,
            licenses=licenses,
            success="Lisans oluşturuldu",
            new_license_key=license_key
        )

    return render_template(
