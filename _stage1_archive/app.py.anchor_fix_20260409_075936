def days_left_from_expiry(expiry_str):
    from datetime import datetime
    try:
        exp = datetime.strptime(expiry_str, "%Y-%m-%d").date()
        today = datetime.utcnow().date()
        return (exp - today).days
    except Exception:
        return -1

