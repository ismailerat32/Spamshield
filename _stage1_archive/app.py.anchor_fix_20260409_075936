def generate_license_key():
    import random
    import string
    chars = string.ascii_uppercase + string.digits
    while True:
        parts = []
        for _ in range(3):
            parts.append("".join(random.choice(chars) for _ in range(4)))
        key = "SSHD-" + "-".join(parts)
        licenses = load_licenses()
        if key not in licenses:
            return key

