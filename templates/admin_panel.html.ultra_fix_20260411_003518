<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SpamShield Admin</title>
  

<style>
:root{
  --bg-1:#020b18;
  --bg-2:#05162e;
  --panel:rgba(15,31,58,.82);
  --panel-2:rgba(19,39,72,.88);
  --line:rgba(255,255,255,.07);
  --line-2:rgba(255,255,255,.10);
  --text:#f8fbff;
  --muted:#9db6e6;
  --blue:#4d8dff;
  --blue-2:#77a8ff;
  --purple:#9b5cf7;
  --yellow:#f7c948;
  --green:#19b36b;
  --red:#e05345;
  --shadow:0 24px 60px rgba(0,0,0,.34);
  --shadow-soft:0 12px 30px rgba(0,0,0,.22);
}

*{box-sizing:border-box}

html,body{
  min-height:100%;
}

body{
  margin:0;
  color:var(--text);
  font-family:Inter, Arial, sans-serif;
  background:
    radial-gradient(circle at 15% 10%, rgba(77,141,255,.14), transparent 28%),
    radial-gradient(circle at 85% 15%, rgba(155,92,247,.12), transparent 24%),
    radial-gradient(circle at 50% 100%, rgba(15,115,255,.08), transparent 35%),
    linear-gradient(180deg, var(--bg-1), var(--bg-2) 55%, #031226);
  padding:24px 16px 44px;
}

body::before{
  content:"";
  position:fixed;
  inset:0;
  pointer-events:none;
  background:
    linear-gradient(rgba(255,255,255,.018), rgba(255,255,255,0)),
    repeating-linear-gradient(
      180deg,
      rgba(255,255,255,.012) 0px,
      rgba(255,255,255,.012) 1px,
      transparent 1px,
      transparent 24px
    );
  opacity:.35;
}

.topbar{
  position:relative;
  display:flex;
  align-items:flex-start;
  justify-content:space-between;
  gap:14px;
  margin-bottom:20px;
  padding:8px 2px 2px;
}

.brand{
  display:flex;
  align-items:flex-start;
  gap:14px;
}

.brand .logo{
  width:58px;
  height:58px;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:44px;
  line-height:1;
  border-radius:18px;
  background:linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,.03));
  border:1px solid rgba(255,255,255,.08);
  box-shadow:var(--shadow-soft);
  backdrop-filter:blur(10px);
  -webkit-backdrop-filter:blur(10px);
}

.brand h1{
  margin:0;
  font-size:31px;
  line-height:0.95;
  font-weight:900;
  letter-spacing:-1px;
  text-shadow:0 4px 20px rgba(0,0,0,.25);
}

.back-link{
  display:inline-flex;
  align-items:center;
  gap:8px;
  color:var(--blue-2);
  text-decoration:none;
  font-weight:800;
  font-size:16px;
  line-height:1.2;
  padding:10px 12px;
  border-radius:14px;
  background:rgba(255,255,255,.03);
  border:1px solid rgba(255,255,255,.04);
  box-shadow:var(--shadow-soft);
}

.main-card{
  position:relative;
  background:linear-gradient(180deg, rgba(17,36,67,.88), rgba(12,28,53,.90));
  border:1px solid var(--line);
  border-radius:30px;
  padding:18px;
  box-shadow:var(--shadow);
  backdrop-filter:blur(14px);
  -webkit-backdrop-filter:blur(14px);
  overflow:hidden;
}

.main-card::before{
  content:"";
  position:absolute;
  inset:0;
  background:
    linear-gradient(135deg, rgba(255,255,255,.05), transparent 30%),
    linear-gradient(180deg, rgba(90,150,255,.05), transparent 45%);
  pointer-events:none;
}

.main-title{
  position:relative;
  z-index:1;
  display:flex;
  align-items:center;
  gap:12px;
  font-size:22px;
  font-weight:900;
  letter-spacing:-.4px;
  margin:4px 4px 16px;
}

.main-title::before{
  content:"⚙️";
  font-size:27px;
  filter:drop-shadow(0 4px 10px rgba(0,0,0,.25));
}

.section{
  position:relative;
  background:linear-gradient(180deg, rgba(255,255,255,.025), rgba(255,255,255,.018));
  border:1px solid rgba(255,255,255,.055);
  border-radius:24px;
  margin-bottom:14px;
  overflow:hidden;
  box-shadow:inset 0 1px 0 rgba(255,255,255,.03);
  transition:transform .28s ease, box-shadow .28s ease, border-color .28s ease;
}

.section:hover{
  transform:translateY(-1px);
  border-color:rgba(255,255,255,.08);
}

.section.active{
  border-color:rgba(100,150,255,.22);
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,.05),
    0 0 0 1px rgba(110,150,255,.05),
    0 18px 50px rgba(0,0,0,.28),
    0 0 34px rgba(73,123,255,.10);
}

.section-toggle{
  width:100%;
  border:0;
  background:transparent;
  color:var(--text);
  text-align:left;
  padding:20px 18px;
  font-size:18px;
  font-weight:850;
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:12px;
  cursor:pointer;
  position:relative;
}

.section-toggle::after{
  content:"";
  position:absolute;
  left:18px;
  right:18px;
  bottom:0;
  height:1px;
  background:linear-gradient(90deg, rgba(255,255,255,.08), rgba(255,255,255,0));
  opacity:.35;
}

.section.active .section-toggle::before{
  content:"";
  position:absolute;
  left:0;
  top:0;
  width:100%;
  height:100%;
  background:linear-gradient(90deg, rgba(77,141,255,.06), transparent 35%);
  pointer-events:none;
}

.section-toggle > span:first-child{
  display:flex;
  align-items:center;
  gap:12px;
  letter-spacing:-.3px;
}

.section-toggle > span:last-child{
  width:30px;
  height:30px;
  min-width:30px;
  display:flex;
  align-items:center;
  justify-content:center;
  border-radius:999px;
  background:rgba(255,255,255,.04);
  border:1px solid rgba(255,255,255,.06);
  transition:transform .28s ease, background .28s ease;
}

.section.active .section-toggle > span:last-child{
  transform:rotate(180deg);
  background:rgba(77,141,255,.12);
}

.section-content{
  max-height:0;
  overflow:hidden;
  transition:max-height .38s ease, padding .32s ease, opacity .22s ease;
  padding:0 18px;
  opacity:0;
}

.section.active .section-content{
  max-height:5000px;
  padding:0 18px 18px;
  opacity:1;
}

.card,
.user-card{
  background:linear-gradient(180deg, rgba(255,255,255,.03), rgba(255,255,255,.022));
  border:1px solid rgba(255,255,255,.05);
  border-radius:22px;
  padding:18px;
  margin-top:14px;
  box-shadow:var(--shadow-soft);
}

input, select, button{
  width:100%;
  border:none;
  border-radius:18px;
  padding:18px 16px;
  font-size:16px;
  margin-top:12px;
}

input, select{
  color:#fff;
  background:linear-gradient(180deg, rgba(34,52,90,.98), rgba(29,45,78,.98));
  border:1px solid rgba(255,255,255,.05);
  outline:none;
  box-shadow:inset 0 1px 0 rgba(255,255,255,.02);
}

input::placeholder{
  color:rgba(220,230,255,.45);
}

input:focus, select:focus{
  border-color:rgba(92,140,255,.45);
  box-shadow:0 0 0 3px rgba(77,141,255,.12);
}

button{
  cursor:pointer;
  font-weight:800;
}

button.primary{
  background:linear-gradient(135deg, #3d6df2, #4c87ff);
  color:#fff;
  box-shadow:0 16px 28px rgba(50,90,220,.28);
}

button.primary:active{
  transform:translateY(1px);
}

.user-name{
  font-size:25px;
  font-weight:900;
  margin:0 0 12px;
  letter-spacing:-.8px;
}

.badges{
  display:flex;
  gap:10px;
  flex-wrap:wrap;
  margin-bottom:12px;
}

.badge{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  padding:10px 14px;
  border-radius:999px;
  font-weight:850;
  font-size:14px;
  letter-spacing:-.2px;
  border:1px solid rgba(255,255,255,.06);
  box-shadow:inset 0 1px 0 rgba(255,255,255,.05);
}

.b-role{
  background:linear-gradient(135deg, rgba(52,103,240,.90), rgba(64,117,255,.76));
}
.b-license{
  background:linear-gradient(135deg, rgba(149,73,201,.92), rgba(171,91,223,.78));
}
.b-active{
  background:linear-gradient(135deg, rgba(24,163,74,.94), rgba(31,185,96,.78));
}

.meta{
  font-size:15px;
  color:#d9e5ff;
  opacity:.92;
  margin:10px 0 0;
}

.license-box{
  margin-top:14px;
  background:linear-gradient(180deg, rgba(255,255,255,.032), rgba(255,255,255,.02));
  border:1px solid rgba(255,255,255,.05);
  border-radius:16px;
  padding:16px;
  font-size:15px;
  font-weight:850;
  word-break:break-word;
}

.row-actions{
  display:flex;
  gap:12px;
  margin-top:14px;
  flex-wrap:wrap;
}

.btn-small{
  width:auto;
  min-width:120px;
  padding:14px 18px;
  font-size:15px;
  font-weight:850;
  border-radius:16px;
  color:#fff;
  border:none;
}

.btn-purple{
  background:linear-gradient(135deg, #9b52d1, #b567e8);
  box-shadow:0 10px 22px rgba(155,82,209,.22);
}

.btn-red{
  background:linear-gradient(135deg, #d54935, #e65b46);
  box-shadow:0 10px 22px rgba(213,73,53,.22);
}

.empty-note{
  opacity:.78;
  font-size:14px;
  color:var(--muted);
  margin-top:10px;
}

.section:nth-of-type(1) .section-toggle > span:first-child{ color:#63a5ff; }
.section:nth-of-type(2) .section-toggle > span:first-child{ color:#b28bff; }
.section:nth-of-type(3) .section-toggle > span:first-child{ color:#ffd34f; }

.toast-container{
  position:fixed;
  top:14px;
  right:14px;
  z-index:9999;
}

@media (max-width:640px){
  body{
    padding:20px 14px 40px;
  }

  .brand .logo{
    width:52px;
    height:52px;
    font-size:38px;
  }

  .brand h1{
    font-size:30px;
  }

  .back-link{
    font-size:15px;
    padding:8px 10px;
  }

  .main-card{
    border-radius:28px;
    padding:16px;
  }

  .main-title{
    font-size:21px;
  }

  .section-toggle{
    font-size:17px;
    padding:18px 16px;
  }

  .card,.user-card{
    padding:16px;
  }

  input,select,button{
    font-size:16px;
  }
}
</style>



<style>
.section{
  transition: all .3s ease;
}

.section.active{
  box-shadow: 0 0 0 1px rgba(255,255,255,.08),
              0 20px 60px rgba(0,0,0,.35),
              0 0 40px rgba(80,120,255,.15);
  transform: translateY(-2px);
}

.section-content{
  transition: max-height .4s ease, padding .3s ease, opacity .3s ease;
  opacity:0;
}

.section.active .section-content{
  opacity:1;
}

.section-toggle{
  position:relative;
}

.section-toggle::after{
  content:"";
  position:absolute;
  left:0;
  bottom:0;
  width:0%;
  height:2px;
  background:linear-gradient(90deg,#4f8cff,#7c5cff);
  transition:.4s;
}

.section.active .section-toggle::after{
  width:100%;
}

.section-toggle span:first-child{
  display:flex;
  align-items:center;
  gap:10px;
}

/* ICON RENKLERİ */
.section:nth-child(1) .section-toggle span:first-child{
  color:#5aa0ff;
}
.section:nth-child(2) .section-toggle span:first-child{
  color:#8b5cf6;
}
.section:nth-child(3) .section-toggle span:first-child{
  color:#facc15;
}
</style>


<style>
.license-box{
  position:relative;
  padding-top:46px;
}

</style>


<style>
.copy-chip{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  margin-left:10px;
  padding:6px 10px;
  border-radius:10px;
  font-size:12px;
  font-weight:800;
  color:#fff;
  background:rgba(255,255,255,.08);
  border:1px solid rgba(255,255,255,.08);
  cursor:pointer;
  user-select:none;
  -webkit-tap-highlight-color:transparent;
  vertical-align:middle;
}

.copy-chip:active{
  transform:translateY(1px);
}

.toast-copy{
  position:fixed;
  left:50%;
  bottom:24px;
  transform:translateX(-50%) translateY(10px);
  background:rgba(10,14,22,.96);
  color:#fff;
  padding:12px 16px;
  border-radius:14px;
  border:1px solid rgba(255,255,255,.08);
  box-shadow:0 16px 40px rgba(0,0,0,.28);
  font-size:14px;
  font-weight:800;
  opacity:0;
  pointer-events:none;
  transition:opacity .25s ease, transform .25s ease;
  z-index:99999;
}

.toast-copy.show{
  opacity:1;
  transform:translateX(-50%) translateY(0);
}
</style>

</head>
<body>

  <div class="topbar">
    <div class="brand">
      <div class="logo">🛡️</div>
      <h1>SpamShield<br>Admin</h1>
    </div>
    <a class="back-link" href="/dashboard">← Dashboard’a dön</a>
  </div>

  <div class="main-card">
    <div class="main-title">Kullanıcı ve Lisans İşlemleri</div>

    <div class="section">
      <button type="button" class="section-toggle">
        <span>👤 Kullanıcı Ekle</span>
        <span>⌄</span>
      </button>
      <div class="section-content">
        <div class="card">
          <form method="POST" action="/admin/add_user">
            <input type="text" name="username" placeholder="Kullanıcı adı" required>
            <input type="password" name="password" placeholder="Şifre" required>

            <select name="role">
              <option value="user">user</option>
              <option value="admin">admin</option>
            </select>

            <select name="license_type">
              <option value="trial">trial</option>
              <option value="pro">pro</option>
            </select>

            <input type="text" name="license_expiry" placeholder="Lisans bitişi (örn: 2099-01-01)">
            <button class="primary" type="submit">Kullanıcı Ekle</button>
          </form>
        </div>
      </div>
    </div>

    <div class="section">
      <button type="button" class="section-toggle">
        <span>📋 Kullanıcılar</span>
        <span>⌄</span>
      </button>
      <div class="section-content">
        {% if users %}
          {% for row in users %}
            <div class="user-card">
              <div class="user-name">{{ row.username }}</div>

              <div class="badges">
                <span class="badge b-role">Rol: {{ row.role if row.role else 'user' }}</span>
                <span class="badge b-license">Lisans: {{ row.license_type if row.license_type else 'trial' }}</span>
                <span class="badge b-active">AKTİF</span>
              </div>

              <div class="meta">Bitiş: {{ row.license_expiry if row.license_expiry else '-' }}</div>

              {% if row.license_key %}
                <div class="license-box">Lisans Kodu: {{ row.license_key }} <span class="copy-chip" data-copy="{{ row.license_key }}">Kopyala</span></div>
              {% endif %}

              <form method="POST" action="/admin/update_license">
                <input type="hidden" name="username" value="{{ row.username }}">

                <select name="license_type">
                  <option value="trial" {% if row.license_type == 'trial' %}selected{% endif %}>trial</option>
                  <option value="pro" {% if row.license_type == 'pro' %}selected{% endif %}>pro</option>
                </select>

                <input type="text" name="license_expiry" value="{{ row.license_expiry if row.license_expiry else '' }}" placeholder="YYYY-AA-GG">

                <button class="primary" type="submit">Lisans Güncelle</button>
              </form>

              <div class="row-actions">
                <form method="POST" action="/admin/generate_license" style="margin:0;">
                  <input type="hidden" name="username" value="{{ row.username }}">
                  <button class="btn-small btn-purple" type="submit">Lisans Üret</button>
                </form>

                <form method="POST" action="/admin/ban_user" style="margin:0;">
                  <input type="hidden" name="username" value="{{ row.username }}">
                  <button class="btn-small btn-red" type="submit">Banla</button>
                </form>
              </div>
            </div>
          {% endfor %}
        {% else %}
          <div class="empty-note">Henüz kullanıcı yok.</div>
        {% endif %}
      </div>
    </div>

    <div class="section">
      <button type="button" class="section-toggle">
        <span>⭐ Yükseltme Talepleri</span>
        <span>⌄</span>
      </button>
      <div class="section-content">
        <div class="card">
          {% if upgrade_requests %}
            {% for req in upgrade_requests %}
              <div class="user-card">
                <div class="user-name">{{ req.username }}</div>
                <div class="meta">Talep: {{ req.request_type if req.request_type else 'upgrade' }}</div>
                <div class="meta">Tarih: {{ req.created_at if req.created_at else '-' }}</div>
              </div>
            {% endfor %}
          {% else %}
            <div class="empty-note">Bekleyen yükseltme talebi yok.</div>
          {% endif %}
        </div>
      </div>
    </div>

  </div>

  <script>
    document.addEventListener("DOMContentLoaded", function () {
      document.querySelectorAll(".section").forEach(function(section, index){
        const btn = section.querySelector(".section-toggle");
        btn.addEventListener("click", function(){
          section.classList.toggle("active");
        });
      });
    });
  </script>





