<script>
/* RADIAL_FORCE_BIND_START */
document.addEventListener("DOMContentLoaded", function () {
    const items = [
        { title: "Koruma", desc: "Koruma modülü açılır." },
        { title: "Analiz", desc: "Analiz modülü açılır." },
        { title: "Engellenenler", desc: "Engellenen mesajlar listelenir." },
        { title: "Bildirimler", desc: "Bildirim merkezi açılır." },
        { title: "Ayarlar", desc: "Uygulama ayarları açılır." },
        { title: "Raporlar", desc: "Rapor ekranı açılır." },
        { title: "Topluluk", desc: "Topluluk özellikleri açılır." },
        { title: "Lisans", desc: "Lisans yönetimi açılır." }
    ];

    const slices = Array.from(document.querySelectorAll(".slice"));
    const labels = Array.from(document.querySelectorAll(".label"));

    function getLabel(i){
        return labels[i] || null;
    }

    function forceReset(){
        slices.forEach((slice, i) => {
            const label = getLabel(i);

            slice.classList.remove("active", "dim");
            slice.style.transform = "translate(0px,0px) scale(1)";
            slice.style.opacity = "1";
            slice.style.pointerEvents = "auto";
            slice.style.cursor = "pointer";

            if(label){
                label.classList.remove("dim");
                label.style.transform = "translate(0px,0px) scale(1)";
                label.style.opacity = "1";
                label.style.pointerEvents = "none";
            }
        });
    }

    window.selectSlice = function(index, title, desc){
        forceReset();

        slices.forEach((slice, i) => {
            const label = getLabel(i);

            if(i !== index){
                const angle = (i * 45) * (Math.PI / 180);
                const x = Math.cos(angle) * -38;
                const y = Math.sin(angle) * -38;

                slice.classList.add("dim");
                slice.style.transform = `translate(${x}px, ${y}px) scale(0.86)`;

                if(label){
                    label.classList.add("dim");
                    label.style.transform = `translate(${x}px, ${y}px) scale(0.86)`;
                }
            }
        });

        const activeSlice = slices[index];
        const activeLabel = getLabel(index);

        if(activeSlice){
            const angle = (index * 45) * (Math.PI / 180);
            const x = Math.cos(angle) * 56;
            const y = Math.sin(angle) * 56;

            activeSlice.classList.add("active");
            activeSlice.style.transform = `translate(${x}px, ${y}px) scale(1.18)`;
        }

        if(activeLabel){
            const angle = (index * 45) * (Math.PI / 180);
            const x = Math.cos(angle) * 56;
            const y = Math.sin(angle) * 56;
            activeLabel.style.transform = `translate(${x}px, ${y}px) scale(1.18)`;
        }

        const titleEl = document.getElementById("featureTitle");
        const descEl = document.getElementById("featureDesc");

        if(titleEl) titleEl.textContent = title;
        if(descEl) descEl.textContent = desc;

        console.log("RADIAL_OK", index, title, "slices=", slices.length, "labels=", labels.length);
    };

    forceReset();

    slices.forEach((slice, i) => {
        const item = items[i] || { title: `Modül ${i+1}`, desc: `Modül ${i+1} açılır.` };

        slice.style.pointerEvents = "auto";
        slice.style.cursor = "pointer";

        slice.addEventListener("click", function(e){
            e.preventDefault();
            e.stopPropagation();
            window.selectSlice(i, item.title, item.desc);
        });

        slice.addEventListener("touchstart", function(e){
            e.preventDefault();
            e.stopPropagation();
            window.selectSlice(i, item.title, item.desc);
        }, { passive: false });
    });

    const buttons = Array.from(document.querySelectorAll(".btn"));
    if(buttons.length > 0){
        buttons[0].addEventListener("click", function(e){
            e.preventDefault();
            forceReset();
            const titleEl = document.getElementById("featureTitle");
            const descEl = document.getElementById("featureDesc");
            if(titleEl) titleEl.textContent = "SpamShield PRO";
            if(descEl) descEl.textContent = "Bir dilime dokun ve ilgili modülü aç.";
        });
    }
});
/* RADIAL_FORCE_BIND_END */
</script>

</body>
</html>
