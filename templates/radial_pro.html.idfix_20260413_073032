<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SpamShield PRO Radial</title>
<style>
:root{
    --bg1:#02060d;
    --bg2:#06111d;
    --line:rgba(0,255,170,.18);
    --line-strong:rgba(120,255,190,.55);
    --fill:rgba(0,255,150,.07);
    --fill-hover:rgba(0,255,150,.14);
    --fill-active:rgba(0,255,150,.28);
    --text:#e8fff2;
    --muted:#9dd8b3;
    --core1:#0dff9a;
    --core2:#00d07d;
    --shadow:0 0 18px rgba(0,255,140,.20), 0 0 45px rgba(0,255,140,.12);
}

*{box-sizing:border-box}

html,body{
    margin:0;
    width:100%;
    height:100%;
    overflow:hidden;
    font-family:Arial, Helvetica, sans-serif;
    color:var(--text);
    background:
        radial-gradient(circle at 50% 42%, rgba(30,255,160,.10), transparent 22%),
        radial-gradient(circle at 50% 55%, rgba(20,140,90,.08), transparent 34%),
        linear-gradient(180deg, var(--bg2), var(--bg1) 60%, #01040a);
}

body{
    display:flex;
    align-items:center;
    justify-content:center;
}

.stars,
.stars::before,
.stars::after{
    position:fixed;
    inset:0;
    content:"";
    pointer-events:none;
}
.stars{
    background-image:
      radial-gradient(circle at 20% 30%, rgba(160,255,200,.8) 0 1px, transparent 1.8px),
      radial-gradient(circle at 70% 20%, rgba(160,255,200,.7) 0 1px, transparent 1.8px),
      radial-gradient(circle at 80% 70%, rgba(160,255,200,.65) 0 1.2px, transparent 2px),
      radial-gradient(circle at 30% 80%, rgba(160,255,200,.55) 0 1px, transparent 1.8px),
      radial-gradient(circle at 55% 60%, rgba(160,255,200,.6) 0 1px, transparent 1.8px);
    opacity:.45;
}
.stars::before{
    background-image:
      radial-gradient(circle at 12% 18%, rgba(120,255,185,.55) 0 1px, transparent 1.8px),
      radial-gradient(circle at 85% 14%, rgba(120,255,185,.45) 0 1px, transparent 1.8px),
      radial-gradient(circle at 76% 84%, rgba(120,255,185,.45) 0 1px, transparent 1.8px),
      radial-gradient(circle at 24% 70%, rgba(120,255,185,.40) 0 1px, transparent 1.8px);
    opacity:.35;
}
.stars::after{
    background:
      radial-gradient(circle at 50% 50%, rgba(0,255,170,.08), transparent 35%);
    filter:blur(18px);
    opacity:.9;
}

.wrap{
    position:relative;
    width:min(92vw, 520px);
    aspect-ratio:1/1.2;
    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;
}

.title{
    margin-top:18px;
    font-size:clamp(26px, 5vw, 40px);
    font-weight:700;
    letter-spacing:.5px;
    color:#9bf3ad;
    text-shadow:0 0 18px rgba(80,255,160,.18);
    user-select:none;
}

.circle{
    position:relative;
    width:min(84vw, 420px);
    height:min(84vw, 420px);
    display:grid;
    place-items:center;
    filter:drop-shadow(0 0 25px rgba(0,255,140,.10));
}

.ringGlow{
    position:absolute;
    width:100%;
    height:100%;
    border-radius:50%;
    box-shadow:
      inset 0 0 30px rgba(0,255,160,.06),
      0 0 30px rgba(0,255,160,.08),
      0 0 60px rgba(0,255,160,.06);
    pointer-events:none;
}

svg{
    width:100%;
    height:100%;
    overflow:visible;
}

.slice{
    fill:var(--fill);
    stroke:var(--line);
    stroke-width:1.3;
    transition:
      transform .28s ease,
      opacity .28s ease,
      fill .28s ease,
      stroke .28s ease,
      filter .28s ease;
    transform-box:fill-box;
    transform-origin:50% 50%;
    transform-origin:center;
    cursor:pointer;
}

.slice:hover{
    fill:var(--fill-hover);
    stroke:rgba(130,255,205,.40);
    filter:drop-shadow(0 0 10px rgba(0,255,160,.08));
}

.slice.dim{
    opacity:.14;
    transform:scale(.97);
}

.slice.active{
    fill:var(--fill-active);
    stroke:var(--line-strong);
    filter:drop-shadow(0 0 14px rgba(0,255,170,.18));
}

.label{
    font-size:8.4px;
    fill:var(--text);
    text-anchor:middle;
    dominant-baseline:middle;
    pointer-events:none;
    user-select:none;
    transition:opacity .28s ease, transform .28s ease;
}

.label.dim{
    opacity:.18;
}

.core{
    position:absolute;
    width:112px;
    height:112px;
    border-radius:50%;
    display:grid;
    place-items:center;
    z-index:3;
    background:
      radial-gradient(circle at 35% 30%, #1cffae, var(--core2) 55%, #00a961 100%);
    box-shadow:
      0 0 0 6px rgba(50,255,160,.08),
      0 0 0 12px rgba(50,255,160,.05),
      0 0 24px rgba(0,255,160,.25),
      0 0 60px rgba(0,255,160,.14),
      inset 0 0 18px rgba(255,255,255,.10);
    border:1px solid rgba(255,255,255,.08);
    user-select:none;
}

.core::before{
    content:"";
    position:absolute;
    inset:10px;
    border-radius:50%;
    border:1px solid rgba(255,255,255,.10);
    box-shadow:inset 0 0 15px rgba(255,255,255,.06);
}

.core span{
    position:relative;
    z-index:2;
    font-size:22px;
    font-weight:800;
    color:#032313;
    letter-spacing:.8px;
    text-shadow:0 1px 0 rgba(255,255,255,.20);
}

.info{
    margin-top:18px;
    min-height:64px;
    text-align:center;
    padding:0 12px;
}

.info h2{
    margin:0 0 6px;
    font-size:clamp(22px, 4.2vw, 28px);
    color:#f2fff7;
    text-shadow:0 0 16px rgba(0,255,160,.10);
}

.info p{
    margin:0;
    color:var(--muted);
    font-size:14px;
}

.actions{
    margin-top:18px;
    display:flex;
    gap:10px;
    flex-wrap:wrap;
    align-items:center;
    justify-content:center;
}

.btn{
    appearance:none;
    border:none;
    outline:none;
    border-radius:999px;
    padding:10px 16px;
    background:rgba(10,26,36,.75);
    color:#d7ffe8;
    border:1px solid rgba(120,255,190,.14);
    box-shadow:inset 0 0 10px rgba(0,255,160,.03);
    font-size:14px;
}

.btn.secondary{
    background:rgba(6,18,26,.58);
    color:#9ed9b6;
}

@media (max-width:430px){
    .core{
        width:96px;
        height:96px;
    }
    .core span{
        font-size:20px;
    }
    .info{
        margin-top:12px;
        min-height:54px;
    }
}
</style>
</head>
<body>
<div class="stars"></div>

<div class="wrap">
    <div class="circle">
        <div class="ringGlow"></div>

        <svg viewBox="0 0 200 200" aria-label="SpamShield radial menu">
            <g id="sliceGroup">
                <path id="slice-0" class="slice" d="M100 100 L100 0 A100 100 0 0 1 170.71 29.29 Z" onclick="selectSlice(0,'Analiz','Mesaj analizi ve spam tespit merkezi')" />
                <path id="slice-1" class="slice" d="M100 100 L170.71 29.29 A100 100 0 0 1 200 100 Z" onclick="selectSlice(1,'Engellenenler','Engellenen mesajlar ve kara liste görünümü')" />
                <path id="slice-2" class="slice" d="M100 100 L200 100 A100 100 0 0 1 170.71 170.71 Z" onclick="selectSlice(2,'Bildirimler','Kritik uyarılar ve olay bildirimleri')" />
                <path id="slice-3" class="slice" d="M100 100 L170.71 170.71 A100 100 0 0 1 100 200 Z" onclick="selectSlice(3,'Ayarlar','Sistem tercihleri ve güvenlik ayarları')" />
                <path id="slice-4" class="slice" d="M100 100 L100 200 A100 100 0 0 1 29.29 170.71 Z" onclick="selectSlice(4,'Raporlar','İstatistikler, günlükler ve özet raporlar')" />
                <path id="slice-5" class="slice" d="M100 100 L29.29 170.71 A100 100 0 0 1 0 100 Z" onclick="selectSlice(5,'Topluluk','Topluluk, geri bildirim ve paylaşım alanı')" />
                <path id="slice-6" class="slice" d="M100 100 L0 100 A100 100 0 0 1 29.29 29.29 Z" onclick="selectSlice(6,'Lisans','Lisans durumu, aktivasyon ve premium erişim')" />
                <path id="slice-7" class="slice" d="M100 100 L29.29 29.29 A100 100 0 0 1 100 0 Z" onclick="selectSlice(7,'Koruma','Canlı koruma ve aktif savunma merkezi')" />
            </g>

            <g id="labelGroup">
                <text id="label-0" class="label" x="125" y="34">Analiz</text>
                <text id="label-1" class="label" x="166" y="75">Engellenenler</text>
                <text id="label-2" class="label" x="166" y="126">Bildirimler</text>
                <text id="label-3" class="label" x="126" y="166">Ayarlar</text>
                <text id="label-4" class="label" x="75" y="166">Raporlar</text>
                <text id="label-5" class="label" x="34" y="126">Topluluk</text>
                <text id="label-6" class="label" x="34" y="75">Lisans</text>
                <text id="label-7" class="label" x="75" y="34">Koruma</text>
            </g>
        </svg>

        <div class="core"><span>PRO</span></div>
    </div>

    <div class="info" id="infoBox">
        <h2>SpamShield PRO</h2>
        <p>Bir dilime dokun ve ilgili modülü aç.</p>
    </div>

    <div class="actions">
        <button class="btn" onclick="resetMenu()">Menüyü Sıfırla</button>
        <button class="btn secondary" onclick="selectSlice(0,'Analiz','Mesaj analizi ve spam tespit merkezi')">Demo Seçim</button>
    </div>

    <div class="title">SpamShield</div>
</div>

<script>
const outward = [
    {x: 0,    y:-10}, // Analiz
    {x: 7,    y:-7},  // Engellenenler
    {x: 10,   y: 0},  // Bildirimler
    {x: 7,    y: 7},  // Ayarlar
    {x: 0,    y:10},  // Raporlar
    {x:-7,    y: 7},  // Topluluk
    {x:-10,   y: 0},  // Lisans
    {x:-7,    y:-7}   // Koruma
];

function resetTransforms(){
    for(let i=0;i<8;i++){
        const slice = document.getElementById(`slice-${i}`);
        const label = document.getElementById(`label-${i}`);
        slice.style.transform = 'translate(0px,0px) scale(1)';
        label.style.transform = 'translate(0px,0px)';
    }
}

function selectSlice(index, title, desc){
    for(let i=0;i<8;i++){
        const slice = document.getElementById(`slice${i}`);
        const label = document.getElementById(`label${i}`);

        slice.classList.remove('active','dim');
        label.classList.remove('dim');

        slice.style.transform = 'translate(0px,0px) scale(1)';
        label.style.transform = 'translate(0px,0px) scale(1)';

        if(i !== index){
            const angle = (i * 45) * (Math.PI/180);

            const x = Math.cos(angle) * -40;
            const y = Math.sin(angle) * -40;

            slice.style.transform = `translate(${x}px, ${y}px) scale(0.85)`;
            label.style.transform = `translate(${x}px, ${y}px) scale(0.85)`;

            slice.classList.add('dim');
            label.classList.add('dim');
        }
    }

    const activeSlice = document.getElementById(`slice${index}`);
    const activeLabel = document.getElementById(`label${index}`);

    const angle = (index * 45) * (Math.PI/180);

    const x = Math.cos(angle) * 55;
    const y = Math.sin(angle) * 55;

    activeSlice.style.transform = `translate(${x}px, ${y}px) scale(1.2)`;
    activeLabel.style.transform = `translate(${x}px, ${y}px) scale(1.2)`;

    activeSlice.classList.add('active');

    document.getElementById('featureTitle').textContent = title;
    document.getElementById('featureDesc').textContent = desc;
}

function resetMenu(){
    for(let i=0;i<8;i++){
        const slice = document.getElementById(`slice-${i}`);
        const label = document.getElementById(`label-${i}`);
        slice.classList.remove('active', 'dim');
        label.classList.remove('dim');
    }
    resetTransforms();
    document.getElementById('infoBox').innerHTML = `
        <h2>SpamShield PRO</h2>
        <p>Bir dilime dokun ve ilgili modülü aç.</p>
    `;
}
</script>

