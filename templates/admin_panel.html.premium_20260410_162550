<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SpamShield Admin</title>
  <style>
    *{box-sizing:border-box}
    body{
      margin:0;
      font-family:Arial,sans-serif;
      background:linear-gradient(180deg,#07152b,#031127 70%,#02101f);
      color:#fff;
      padding:20px 16px 40px;
    }

    .topbar{
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      gap:12px;
      margin-bottom:22px;
    }

    .brand{
      display:flex;
      align-items:flex-start;
      gap:12px;
    }

    .brand .logo{
      font-size:42px;
      line-height:1;
    }

    .brand h1{
      margin:0;
      font-size:30px;
      line-height:1.02;
      font-weight:900;
    }

    .back-link{
      color:#8fb3ff;
      text-decoration:none;
      font-weight:700;
      font-size:16px;
      margin-top:8px;
    }

    .main-card{
      background:linear-gradient(180deg,rgba(18,38,70,.98),rgba(14,31,58,.98));
      border:1px solid rgba(255,255,255,.06);
      border-radius:26px;
      padding:16px;
      box-shadow:0 18px 40px rgba(0,0,0,.22);
      margin-bottom:18px;
    }

    .main-title{
      font-size:22px;
      font-weight:900;
      margin:4px 2px 14px;
    }

    .section{
      background:rgba(255,255,255,.02);
      border:1px solid rgba(255,255,255,.05);
      border-radius:22px;
      margin-bottom:14px;
      overflow:hidden;
    }

    .section-toggle{
      width:100%;
      border:0;
      background:transparent;
      color:#fff;
      text-align:left;
      padding:18px 18px;
      font-size:18px;
      font-weight:800;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      cursor:pointer;
    }

    .section-toggle span:last-child{
      transition:transform .25s ease;
      opacity:.9;
    }

    .section.active .section-toggle span:last-child{
      transform:rotate(180deg);
    }

    .section-content{
      max-height:0;
      overflow:hidden;
      transition:max-height .35s ease, padding .35s ease;
      padding:0 18px;
    }

    .section.active .section-content{
      max-height:5000px;
      padding:0 18px 18px;
    }

    .card{
      background:rgba(255,255,255,.03);
      border-radius:22px;
      padding:18px;
      margin-top:14px;
    }

    input, select, button{
      width:100%;
      border:none;
      border-radius:18px;
      padding:18px 16px;
      font-size:16px;
      margin-top:12px;
    }

    input, select{
      background:#1c2d52;
      color:#fff;
    }

    button.primary{
      background:#3d6df2;
      color:#fff;
      font-weight:800;
    }

    .user-card{
      background:rgba(255,255,255,.03);
      border-radius:22px;
      padding:18px;
      margin-top:14px;
    }

    .user-name{
      font-size:24px;
      font-weight:900;
      margin:0 0 12px;
    }

    .badges{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      margin-bottom:12px;
    }

    .badge{
      display:inline-block;
      padding:10px 14px;
      border-radius:999px;
      font-weight:800;
      font-size:14px;
    }

    .b-role{background:#3467f0}
    .b-license{background:#9549c9}
    .b-active{background:#18a34a}

    .meta{
      font-size:14px;
      opacity:.9;
      margin:8px 0 0;
    }

    .license-box{
      margin-top:14px;
      background:rgba(255,255,255,.03);
      border-radius:16px;
      padding:16px;
      font-size:15px;
      font-weight:800;
      word-break:break-word;
    }

    .row-actions{
      display:flex;
      gap:12px;
      margin-top:14px;
      flex-wrap:wrap;
    }

    .btn-small{
      width:auto;
      min-width:120px;
      padding:14px 18px;
      font-size:15px;
      font-weight:800;
      border-radius:16px;
      color:#fff;
    }

    .btn-purple{background:#a34ecb}
    .btn-red{background:#d44830}

    .empty-note{
      opacity:.75;
      font-size:14px;
      margin-top:10px;
    }
  </style>

<style>
.section{
  transition: all .3s ease;
}

.section.active{
  box-shadow: 0 0 0 1px rgba(255,255,255,.08),
              0 20px 60px rgba(0,0,0,.35),
              0 0 40px rgba(80,120,255,.15);
  transform: translateY(-2px);
}

.section-content{
  transition: max-height .4s ease, padding .3s ease, opacity .3s ease;
  opacity:0;
}

.section.active .section-content{
  opacity:1;
}

.section-toggle{
  position:relative;
}

.section-toggle::after{
  content:"";
  position:absolute;
  left:0;
  bottom:0;
  width:0%;
  height:2px;
  background:linear-gradient(90deg,#4f8cff,#7c5cff);
  transition:.4s;
}

.section.active .section-toggle::after{
  width:100%;
}

.section-toggle span:first-child{
  display:flex;
  align-items:center;
  gap:10px;
}

/* ICON RENKLERİ */
.section:nth-child(1) .section-toggle span:first-child{
  color:#5aa0ff;
}
.section:nth-child(2) .section-toggle span:first-child{
  color:#8b5cf6;
}
.section:nth-child(3) .section-toggle span:first-child{
  color:#facc15;
}
</style>

</head>
<body>

  <div class="topbar">
    <div class="brand">
      <div class="logo">🛡️</div>
      <h1>SpamShield<br>Admin</h1>
    </div>
    <a class="back-link" href="/dashboard">← Dashboard’a dön</a>
  </div>

  <div class="main-card">
    <div class="main-title">⚙️ Kullanıcı ve Lisans İşlemleri</div>

    <div class="section">
      <button type="button" class="section-toggle">
        <span>👤 Kullanıcı Ekle</span>
        <span>⌄</span>
      </button>
      <div class="section-content">
        <div class="card">
          <form method="POST" action="/admin/add_user">
            <input type="text" name="username" placeholder="Kullanıcı adı" required>
            <input type="password" name="password" placeholder="Şifre" required>

            <select name="role">
              <option value="user">user</option>
              <option value="admin">admin</option>
            </select>

            <select name="license_type">
              <option value="trial">trial</option>
              <option value="pro">pro</option>
            </select>

            <input type="text" name="license_expiry" placeholder="Lisans bitişi (örn: 2099-01-01)">
            <button class="primary" type="submit">Kullanıcı Ekle</button>
          </form>
        </div>
      </div>
    </div>

    <div class="section">
      <button type="button" class="section-toggle">
        <span>📋 Kullanıcılar</span>
        <span>⌄</span>
      </button>
      <div class="section-content">
        {% if users %}
          {% for row in users %}
            <div class="user-card">
              <div class="user-name">{{ row.username }}</div>

              <div class="badges">
                <span class="badge b-role">Rol: {{ row.role if row.role else 'user' }}</span>
                <span class="badge b-license">Lisans: {{ row.license_type if row.license_type else 'trial' }}</span>
                <span class="badge b-active">AKTİF</span>
              </div>

              <div class="meta">Bitiş: {{ row.license_expiry if row.license_expiry else '-' }}</div>

              {% if row.license_key %}
                <div class="license-box">Lisans Kodu: {{ row.license_key }}</div>
              {% endif %}

              <form method="POST" action="/admin/update_license">
                <input type="hidden" name="username" value="{{ row.username }}">

                <select name="license_type">
                  <option value="trial" {% if row.license_type == 'trial' %}selected{% endif %}>trial</option>
                  <option value="pro" {% if row.license_type == 'pro' %}selected{% endif %}>pro</option>
                </select>

                <input type="text" name="license_expiry" value="{{ row.license_expiry if row.license_expiry else '' }}" placeholder="YYYY-AA-GG">

                <button class="primary" type="submit">Lisans Güncelle</button>
              </form>

              <div class="row-actions">
                <form method="POST" action="/admin/generate_license" style="margin:0;">
                  <input type="hidden" name="username" value="{{ row.username }}">
                  <button class="btn-small btn-purple" type="submit">Lisans Üret</button>
                </form>

                <form method="POST" action="/admin/ban_user" style="margin:0;">
                  <input type="hidden" name="username" value="{{ row.username }}">
                  <button class="btn-small btn-red" type="submit">Banla</button>
                </form>
              </div>
            </div>
          {% endfor %}
        {% else %}
          <div class="empty-note">Henüz kullanıcı yok.</div>
        {% endif %}
      </div>
    </div>

    <div class="section">
      <button type="button" class="section-toggle">
        <span>⭐ Yükseltme Talepleri</span>
        <span>⌄</span>
      </button>
      <div class="section-content">
        <div class="card">
          {% if upgrade_requests %}
            {% for req in upgrade_requests %}
              <div class="user-card">
                <div class="user-name">{{ req.username }}</div>
                <div class="meta">Talep: {{ req.request_type if req.request_type else 'upgrade' }}</div>
                <div class="meta">Tarih: {{ req.created_at if req.created_at else '-' }}</div>
              </div>
            {% endfor %}
          {% else %}
            <div class="empty-note">Bekleyen yükseltme talebi yok.</div>
          {% endif %}
        </div>
      </div>
    </div>

  </div>

  <script>
    document.addEventListener("DOMContentLoaded", function () {
      document.querySelectorAll(".section").forEach(function(section, index){
        const btn = section.querySelector(".section-toggle");
        btn.addEventListener("click", function(){
          section.classList.toggle("active");
        });
      });
    });
  </script>

</body>
</html>
