<!DOCTYPE html>
<html lang="tr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SpamShield Admin</title>
  <style>
    :root{
      --bg1:#020b18;
      --bg2:#05162d;
      --panel:rgba(14,30,56,.88);
      --panel2:rgba(19,39,72,.94);
      --line:rgba(255,255,255,.07);
      --text:#f8fbff;
      --muted:#9db5df;
      --blue:#4d8dff;
      --blue2:#78a9ff;
      --purple:#a066ff;
      --yellow:#ffd34f;
      --green:#1db56e;
      --red:#e85a4f;
      --shadow:0 22px 60px rgba(0,0,0,.34);
      --shadow-soft:0 12px 28px rgba(0,0,0,.24);
    }

    *{box-sizing:border-box}
    html,body{min-height:100%}

    body{
      margin:0;
      color:var(--text);
      font-family:Inter, Arial, sans-serif;
      background:
        radial-gradient(circle at 12% 10%, rgba(77,141,255,.14), transparent 26%),
        radial-gradient(circle at 88% 14%, rgba(160,102,255,.12), transparent 24%),
        radial-gradient(circle at 50% 100%, rgba(40,110,255,.08), transparent 36%),
        linear-gradient(180deg, var(--bg1), var(--bg2) 56%, #041224);
      padding:22px 15px 42px;
    }

    body::before{
      content:"";
      position:fixed;
      inset:0;
      pointer-events:none;
      background:
        linear-gradient(rgba(255,255,255,.018), rgba(255,255,255,0)),
        repeating-linear-gradient(
          180deg,
          rgba(255,255,255,.012) 0px,
          rgba(255,255,255,.012) 1px,
          transparent 1px,
          transparent 26px
        );
      opacity:.28;
    }

    .topbar{
      display:flex;
      align-items:flex-start;
      justify-content:space-between;
      gap:14px;
      margin-bottom:20px;
    }

    .brand{
      display:flex;
      align-items:flex-start;
      gap:14px;
    }

    .brand .logo{
      width:58px;
      height:58px;
      display:flex;
      align-items:center;
      justify-content:center;
      font-size:42px;
      border-radius:18px;
      background:linear-gradient(180deg, rgba(255,255,255,.10), rgba(255,255,255,.03));
      border:1px solid rgba(255,255,255,.08);
      backdrop-filter:blur(12px);
      -webkit-backdrop-filter:blur(12px);
      box-shadow:var(--shadow-soft);
    }

    .brand h1{
      margin:0;
      font-size:31px;
      line-height:.95;
      font-weight:900;
      letter-spacing:-1px;
      text-shadow:0 8px 24px rgba(0,0,0,.28);
    }

    .back-link{
      display:inline-flex;
      align-items:center;
      gap:8px;
      padding:10px 12px;
      border-radius:15px;
      text-decoration:none;
      color:var(--blue2);
      font-weight:800;
      font-size:16px;
      background:rgba(255,255,255,.03);
      border:1px solid rgba(255,255,255,.05);
      box-shadow:var(--shadow-soft);
    }

    .main-card{
      position:relative;
      background:linear-gradient(180deg, rgba(17,36,67,.90), rgba(12,28,53,.92));
      border:1px solid var(--line);
      border-radius:30px;
      padding:18px;
      box-shadow:var(--shadow);
      overflow:hidden;
      backdrop-filter:blur(14px);
      -webkit-backdrop-filter:blur(14px);
    }

    .main-card::before{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background:
        linear-gradient(135deg, rgba(255,255,255,.05), transparent 30%),
        linear-gradient(180deg, rgba(77,141,255,.05), transparent 45%);
    }

    .main-title{
      position:relative;
      z-index:1;
      display:flex;
      align-items:center;
      gap:12px;
      margin:4px 4px 16px;
      font-size:23px;
      font-weight:900;
      letter-spacing:-.4px;
    }

    .main-title::before{
      content:"⚙️";
      font-size:26px;
    }

    .section{
      position:relative;
      background:linear-gradient(180deg, rgba(255,255,255,.028), rgba(255,255,255,.018));
      border:1px solid rgba(255,255,255,.055);
      border-radius:24px;
      margin-bottom:14px;
      overflow:hidden;
      box-shadow:inset 0 1px 0 rgba(255,255,255,.03);
      transition:transform .25s ease, box-shadow .25s ease, border-color .25s ease;
    }

    .section.active{
      border-color:rgba(100,150,255,.20);
      box-shadow:
        inset 0 1px 0 rgba(255,255,255,.05),
        0 18px 52px rgba(0,0,0,.28),
        0 0 34px rgba(73,123,255,.10);
    }

    .section-toggle{
      width:100%;
      border:0;
      background:transparent;
      color:var(--text);
      text-align:left;
      padding:20px 18px;
      font-size:18px;
      font-weight:850;
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap:12px;
      cursor:pointer;
    }

    .section-toggle .left{
      display:flex;
      align-items:center;
      gap:12px;
    }

    .section-toggle .icon{
      font-size:28px;
      line-height:1;
    }

    .section-toggle .chev{
      width:34px;
      height:34px;
      border-radius:999px;
      display:flex;
      align-items:center;
      justify-content:center;
      background:rgba(255,255,255,.04);
      border:1px solid rgba(255,255,255,.06);
      transition:transform .25s ease, background .25s ease;
    }

    .section.active .section-toggle .chev{
      transform:rotate(180deg);
      background:rgba(77,141,255,.12);
    }

    .section-content{
      display:none;
      padding:0 18px 18px;
    }

    .section.active .section-content{
      display:block;
    }

    .card,
    .user-card{
      background:linear-gradient(180deg, rgba(255,255,255,.032), rgba(255,255,255,.022));
      border:1px solid rgba(255,255,255,.055);
      border-radius:22px;
      padding:18px;
      margin-top:14px;
      box-shadow:var(--shadow-soft);
    }

    input, select, button{
      width:100%;
      border:none;
      border-radius:18px;
      padding:18px 16px;
      font-size:16px;
      margin-top:12px;
    }

    input, select{
      color:#fff;
      background:linear-gradient(180deg, rgba(34,52,90,.98), rgba(29,45,78,.98));
      border:1px solid rgba(255,255,255,.05);
      outline:none;
    }

    input::placeholder{
      color:rgba(220,230,255,.45);
    }

    button{
      cursor:pointer;
      font-weight:800;
    }

    button.primary{
      background:linear-gradient(135deg, #3d6df2, #4d89ff);
      color:#fff;
      box-shadow:0 16px 28px rgba(50,90,220,.28);
    }

    .user-name{
      font-size:25px;
      font-weight:900;
      letter-spacing:-.8px;
      margin:0 0 12px;
    }

    .badges{
      display:flex;
      gap:10px;
      flex-wrap:wrap;
      margin-bottom:12px;
    }

    .badge{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      padding:10px 14px;
      border-radius:999px;
      font-weight:850;
      font-size:14px;
      border:1px solid rgba(255,255,255,.06);
    }

    .b-role{ background:linear-gradient(135deg, rgba(52,103,240,.90), rgba(64,117,255,.76)); }
    .b-license{ background:linear-gradient(135deg, rgba(149,73,201,.92), rgba(171,91,223,.78)); }
    .b-active{ background:linear-gradient(135deg, rgba(24,163,74,.94), rgba(31,185,96,.78)); }

    .meta{
      font-size:15px;
      color:#d9e5ff;
      opacity:.92;
      margin:10px 0 0;
    }

    .license-box{
      margin-top:14px;
      background:linear-gradient(180deg, rgba(255,255,255,.032), rgba(255,255,255,.02));
      border:1px solid rgba(255,255,255,.05);
      border-radius:16px;
      padding:16px;
      font-size:15px;
      font-weight:850;
      word-break:break-word;
      cursor:pointer;
      user-select:none;
      -webkit-tap-highlight-color:transparent;
    }

    .license-box:active{
      transform:scale(.99);
    }

    .row-actions{
      display:flex;
      gap:12px;
      margin-top:14px;
      flex-wrap:wrap;
    }

    .row-actions form{
      flex:1 1 140px;
      margin:0;
    }

    .btn-small{
      width:100%;
      min-width:120px;
      padding:14px 18px;
      font-size:15px;
      font-weight:850;
      border-radius:16px;
      color:#fff;
      border:none;
    }

    .btn-purple{
      background:linear-gradient(135deg, #9b52d1, #b567e8);
      box-shadow:0 10px 22px rgba(155,82,209,.22);
    }

    .btn-red{
      background:linear-gradient(135deg, #d54935, #e65b46);
      box-shadow:0 10px 22px rgba(213,73,53,.22);
    }

    .empty-note{
      opacity:.78;
      font-size:14px;
      color:var(--muted);
      margin-top:10px;
    }

    .toast-copy{
      position:fixed;
      left:50%;
      bottom:24px;
      transform:translateX(-50%) translateY(10px);
      background:rgba(10,14,22,.96);
      color:#fff;
      padding:12px 16px;
      border-radius:14px;
      border:1px solid rgba(255,255,255,.08);
      box-shadow:0 16px 40px rgba(0,0,0,.28);
      font-size:14px;
      font-weight:800;
      opacity:0;
      pointer-events:none;
      transition:opacity .25s ease, transform .25s ease;
      z-index:99999;
    }

    .toast-copy.show{
      opacity:1;
      transform:translateX(-50%) translateY(0);
    }

    .section.section-add .left{ color:#8d63ff; }
    .section.section-users .left{ color:#ffd34f; }
    .section.section-upgrades .left{ color:#ffffff; }

    @media (max-width:640px){
      body{ padding:20px 14px 40px; }
      .brand .logo{ width:52px; height:52px; font-size:38px; }
      .brand h1{ font-size:30px; }
      .back-link{ font-size:15px; padding:8px 10px; }
      .main-card{ border-radius:28px; padding:16px; }
      .main-title{ font-size:21px; }
      .section-toggle{ font-size:17px; padding:18px 16px; }
      .card,.user-card{ padding:16px; }
      .user-name{ font-size:23px; }
    }
  </style>
</head>
<body>

  <div class="topbar">
    <div class="brand">
      <div class="logo">🛡️</div>
      <h1>SpamShield<br>Admin</h1>
    </div>
    <a class="back-link" href="/dashboard">← Dashboard’a dön</a>
  </div>

  <div class="main-card">
    <div class="main-title">Kullanıcı ve Lisans İşlemleri</div>

    <div class="section section-add" id="section-add">
      <button type="button" class="section-toggle">
        <div class="left">
          <span class="icon">👤</span>
          <span>Kullanıcı Ekle</span>
        </div>
        <div class="chev">˅</div>
      </button>
      <div class="section-content">
        <div class="card">
          <form method="POST" action="/admin/add-user">
            <input type="text" name="username" placeholder="Kullanıcı adı" required>
            <input type="password" name="password" placeholder="Şifre" required>

            <select name="role">
              <option value="user">user</option>
              <option value="admin">admin</option>
            </select>

            <select name="license_type">
              <option value="trial">trial</option>
              <option value="pro">pro</option>
            </select>

            <input type="text" name="license_expiry" placeholder="Lisans bitişi (örn: 2099-01-01)">
            <button class="primary" type="submit">Kullanıcı Ekle</button>
          </form>
        </div>
      </div>
    </div>

    <div class="section section-users" id="section-users">
      <button type="button" class="section-toggle">
        <div class="left">
          <span class="icon">📋</span>
          <span>Kullanıcılar</span>
        </div>
        <div class="chev">˅</div>
      </button>
      <div class="section-content">
        {% if users %}
          {% for row in users %}
            <div class="user-card">
              <div class="user-name">{{ row.username }}</div>

              <div class="badges">
                <span class="badge b-role">Rol: {{ row.role if row.role else 'user' }}</span>
                <span class="badge b-license">Lisans: {{ row.license_type if row.license_type else 'trial' }}</span>
                <span class="badge b-active">AKTİF</span>
              </div>

              <div class="meta">Bitiş: {{ row.license_expiry if row.license_expiry else '-' }}</div>

              {% if row.license_key %}
                <div class="license-box" data-copy="{{ row.license_key }}">Lisans Kodu: {{ row.license_key }}</div>
              {% endif %}

              <form method="POST" action="/admin/update-license/{{ row.username }}">
                <input type="hidden" name="username" value="{{ row.username }}">

                <select name="license_type">
                  <option value="trial" {% if row.license_type == 'trial' %}selected{% endif %}>trial</option>
                  <option value="pro" {% if row.license_type == 'pro' %}selected{% endif %}>pro</option>
                </select>

                <input type="text" name="license_expiry" value="{{ row.license_expiry if row.license_expiry else '' }}" placeholder="YYYY-AA-GG">

                <button class="primary" type="submit">Lisans Güncelle</button>
              </form>

              <div class="row-actions">
                <form method="POST" action="/admin/generate-license/{{ row.username }}">
                  <input type="hidden" name="username" value="{{ row.username }}">
                  <button class="btn-small btn-purple" type="submit">Lisans Üret</button>
                </form>

                <form method="POST" action="/admin/toggle-ban/{{ row.username }}">
                  <input type="hidden" name="username" value="{{ row.username }}">
                  <button class="btn-small btn-red" type="submit">Banla</button>
                </form>
              </div>
            </div>
          {% endfor %}
        {% else %}
          <div class="empty-note">Henüz kullanıcı yok.</div>
        {% endif %}
      </div>
    </div>

    <div class="section section-upgrades" id="section-upgrades">
      <button type="button" class="section-toggle">
        <div class="left">
          <span class="icon">⭐</span>
          <span>Yükseltme Talepleri</span>
        </div>
        <div class="chev">˅</div>
      </button>
      <div class="section-content">
        <div class="card">
          {% if upgrade_requests %}
            {% for req in upgrade_requests %}
              <div class="user-card">
                <div class="user-name">{{ req.username if req.username else 'Bilinmeyen Kullanıcı' }}</div>
                <div class="meta">Talep: {{ req.request_type if req.request_type else 'upgrade' }}</div>
                <div class="meta">Tarih: {{ req.created_at if req.created_at else '-' }}</div>
              </div>
            {% endfor %}
          {% else %}
            <div class="empty-note">Bekleyen yükseltme talebi yok.</div>
          {% endif %}
        </div>
      </div>
    </div>

  </div>

  <script>
    document.addEventListener("DOMContentLoaded", function () {
      const sections = document.querySelectorAll(".section");

      sections.forEach(function(section){
        const toggle = section.querySelector(".section-toggle");
        const content = section.querySelector(".section-content");

        if (toggle && content) {
          toggle.addEventListener("click", function (e) {
            e.preventDefault();
            e.stopPropagation();
            section.classList.toggle("active");
          });
        }
      });

      function showToast(message){
        let toast = document.getElementById("copyToast");
        if(!toast){
          toast = document.createElement("div");
          toast.id = "copyToast";
          toast.className = "toast-copy";
          toast.style.opacity = "0";
toast.style.transition = "all .3s ease";

document.body.appendChild(toast);

setTimeout(()=>{ toast.style.opacity="1"; toast.style.transform="translate(-50%,0)"; },10);

        }
        toast.textContent = message;
        toast.classList.add("show");
        clearTimeout(window.__copyToastTimer);
        window.__copyToastTimer = setTimeout(function(){
          toast.classList.remove("show");
        }, 1500);
      }

      async function copyText(text){
        try{
          if(navigator.clipboard && navigator.clipboard.writeText){
            await navigator.clipboard.writeText(text);
          }else{
            const ta = document.createElement("textarea");
            ta.value = text;
            document.body.appendChild(ta);
            ta.select();
            document.execCommand("copy");
            ta.remove();
          }
          showToast("Lisans kodu kopyalandı");
        }catch(err){
          console.log("copy error:", err);
          showToast("Kopyalama başarısız");
        }
      }

      
      const openSection = new URLSearchParams(window.location.search).get("open");
      if (openSection === "users") {
        const s = document.getElementById("section-users");
        if (s) s.classList.add("active");
      } else if (openSection === "add") {
        const s = document.getElementById("section-add");
        if (s) s.classList.add("active");
      } else if (openSection === "upgrades") {
        const s = document.getElementById("section-upgrades");
        if (s) s.classList.add("active");
      }

document.querySelectorAll(".license-box[data-copy]").forEach(function(el){
        el.addEventListener("click", function(e){
          e.preventDefault();
          e.stopPropagation();
          const text = (el.getAttribute("data-copy") || "").trim();
          if(text) copyText(text);
        });
      });
    });
  </script>


<script>
window.addEventListener("DOMContentLoaded", () => {
  const params = new URLSearchParams(window.location.search);
  const ok = params.get("ok");

  const usersSection = document.querySelector(".section-users");
  if (usersSection) {
    usersSection.classList.add("active");
  }

  if (window.location.hash) {
    const el = document.querySelector(window.location.hash);
    if (el) {
      el.scrollIntoView({ behavior: "smooth", block: "center" });
    }
  }

  if (ok) {
    showTopToast(ok);
  }
});

function showTopToast(type){
  let text = "İşlem tamamlandı";

  if(type === "license_generated") text = "Lisans üretildi";
  if(type === "license_exists") text = "Zaten lisans var";
  if(type === "done") text = "Güncellendi";
  if(type === "user_added") text = "Kullanıcı eklendi";
  if(type === "user_exists") text = "Kullanıcı zaten var";

  let toast = document.createElement("div");
  toast.innerText = text;

  toast.style.position = "fixed";
  toast.style.bottom = "80px";
  toast.style.left = "50%";
  toast.style.transform = "translateX(-50%)";
  toast.style.background = "#1e293b";
  toast.style.color = "#fff";
  toast.style.padding = "10px 16px";
  toast.style.borderRadius = "14px";
  toast.style.zIndex = "9999";
  toast.style.fontWeight = "600";
toast.style.fontSize = "13px";
  toast.style.boxShadow = "0 20px 40px rgba(0,0,0,.45)";

toast.style.border = "1px solid rgba(255,255,255,0.15)";


  toast.style.opacity = "0";
toast.style.transition = "all .3s ease";

document.body.appendChild(toast);

setTimeout(()=>{ toast.style.opacity="1"; toast.style.transform="translate(-50%,0)"; },10);


  setTimeout(() => {
  toast.style.opacity="0";
  setTimeout(()=>toast.remove(),300);
}, 1800);
}
</script>

</body>
</html>
