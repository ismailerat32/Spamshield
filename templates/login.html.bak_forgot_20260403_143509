<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<title>SpamShield Pro</title>
<meta name="viewport" content="width=device-width, initial-scale=1">

<style>
*{box-sizing:border-box}
body{
    margin:0;
    font-family:Arial,sans-serif;
    background: linear-gradient(135deg,#08122e,#10214e,#1b2d6b);
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    color:white;
    overflow-x:hidden;
}
body::before{
    content:"";
    position:fixed;
    inset:0;
    background:
        radial-gradient(circle at top left, rgba(124,58,237,.20), transparent 30%),
        radial-gradient(circle at bottom right, rgba(37,99,235,.20), transparent 30%);
    pointer-events:none;
}
.box{
    position:relative;
    z-index:1;
    width:min(92vw,420px);
    background:rgba(8,18,46,.75);
    border:1px solid rgba(255,255,255,.08);
    backdrop-filter: blur(14px);
    border-radius:24px;
    padding:34px 24px 26px;
    box-shadow:0 20px 50px rgba(0,0,0,.35);
}
.logo{
    text-align:center;
    font-size:58px;
    margin-bottom:6px;
}
h1{
    margin:0;
    text-align:center;
    font-size:34px;
    line-height:1.1;
}
.subtitle{
    text-align:center;
    color:#94a3b8;
    margin:10px 0 24px;
    font-size:15px;
}
label{
    display:block;
    margin:14px 0 8px;
    color:#e5e7eb;
    font-size:15px;
}
input{
    width:100%;
    padding:14px 15px;
    border-radius:14px;
    border:1px solid rgba(255,255,255,.10);
    background:rgba(2,6,23,.45);
    color:white;
    font-size:16px;
    outline:none;
}
input:focus{
    border-color:#3b82f6;
    box-shadow:0 0 0 3px rgba(59,130,246,.18);
}
button{
    width:100%;
    margin-top:18px;
    padding:14px 16px;
    border:none;
    border-radius:14px;
    background:linear-gradient(90deg,#2563eb,#7c3aed);
    color:white;
    font-size:18px;
    font-weight:700;
    cursor:pointer;
    box-shadow:0 10px 24px rgba(37,99,235,.28);
}
button:hover{opacity:.96}
.error{
    margin:14px 0 6px;
    padding:14px;
    border-radius:16px;
    background:rgba(127,29,29,.35);
    border:1px solid rgba(239,68,68,.35);
    color:#fecaca;
    text-align:center;
    font-weight:600;
}
.register{
    margin-top:22px;
    text-align:center;
    color:#e5e7eb;
    font-size:15px;
}
.register a{
    color:#60a5fa;
    text-decoration:none;
    font-weight:700;
}
.copyright{
    position:fixed;
    left:0;
    bottom:0;
    width:100%;
    padding:14px 10px;
    text-align:center;
    font-size:12px;
    color:rgba(255,255,255,.55);
    background:linear-gradient(to top, rgba(2,6,23,.65), transparent);
    backdrop-filter: blur(6px);
}
@media (max-width:480px){
    .box{padding:28px 18px 24px}
    h1{font-size:30px}
}
</style>
</head>
<body>

<div class="box">
    <div class="logo">🛡️</div>
    <h1>SpamShield</h1>
    <div class="subtitle">Yönetim paneline giriş yapın</div>

    {% if error %}
    <div class="error">{{ error }}</div>
    {% endif %}

    <form method="POST">
        <label for="username">Kullanıcı Adı</label>
        <input id="username" name="username" placeholder="Kullanıcı adınızı girin">

        <label for="password">Şifre</label>
        <input id="password" type="password" name="password" placeholder="Şifrenizi girin">

        <button type="submit">Giriş Yap</button>
    </form>

    <div class="register">
        Hesabın yok mu? <a href="/register">Yeni üye ol</a>
    </div>
</div>

<div class="copyright">
    SpamShield © 2026 • All rights reserved • v1.0
</div>

</body>
</html>
