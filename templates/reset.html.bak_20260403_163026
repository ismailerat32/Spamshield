<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Şifreyi Sıfırla - SpamShield</title>
<style>
*{box-sizing:border-box}
body{
    margin:0;
    font-family:Arial,sans-serif;
    background:linear-gradient(135deg,#111827,#0b1f4d,#1e3a8a);
    color:white;
    min-height:100vh;
}
.header{
    padding:18px 22px;
    border-bottom:1px solid rgba(255,255,255,.06);
    background:rgba(2,6,23,.35);
}
.header a{
    color:white;
    text-decoration:none;
    font-weight:bold;
}
.wrap{
    max-width:680px;
    margin:30px auto;
    padding:20px;
}
.card{
    background:#081633;
    border:1px solid rgba(255,255,255,.06);
    border-radius:24px;
    padding:28px;
    box-shadow:0 10px 30px rgba(0,0,0,.22);
}
h1{
    margin:0 0 18px 0;
    font-size:28px;
}
label{
    display:block;
    margin:14px 0 8px;
    color:#d1d5db;
    font-size:15px;
}
input{
    width:100%;
    padding:14px;
    border-radius:14px;
    border:1px solid rgba(255,255,255,.12);
    background:#071127;
    color:white;
    font-size:16px;
}
button{
    width:100%;
    margin-top:18px;
    padding:14px;
    border:none;
    border-radius:14px;
    background:linear-gradient(90deg,#2563eb,#7c3aed);
    color:white;
    font-size:18px;
    font-weight:700;
    cursor:pointer;
}
.msg{
    margin:14px 0;
    padding:14px;
    border-radius:14px;
    font-weight:600;
}
.err{
    background:rgba(127,29,29,.35);
    border:1px solid rgba(239,68,68,.35);
    color:#fecaca;
}
.ok{
    background:rgba(21,128,61,.28);
    border:1px solid rgba(34,197,94,.35);
    color:#bbf7d0;
}
.links{
    margin-top:18px;
    display:flex;
    flex-direction:column;
    gap:10px;
}
.links a{
    color:#8ab4ff;
    text-decoration:none;
}
</style>
</head>
<body>
<div class="header"><a href="/login">← Girişe dön</a></div>

<div class="wrap">
    <div class="card">
        <h1>Şifreyi Sıfırla</h1>

        {% if error %}
        <div class="msg err">{{ error }}</div>
        {% endif %}

        {% if success %}
        <div class="msg ok">{{ success }}</div>
        <div class="links">
            <a href="/login">Giriş sayfasına git</a>
        </div>
        {% endif %}

        <form method="POST">
            <label>Kullanıcı Adı</label>
            <input name="username" placeholder="Kullanıcı adını gir">

            <label>Sıfırlama Kodu</label>
            <input name="code" placeholder="RST-XXXXXXXX">

            <label>Yeni Şifre</label>
            <input type="password" name="password" placeholder="Yeni şifreni gir">

            <button type="submit">Şifreyi Güncelle</button>
        </form>
    </div>
</div>
</body>
</html>
