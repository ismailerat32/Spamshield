<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>SpamShield Premium</title>
<style>
*{box-sizing:border-box}
body{
    margin:0;
    font-family:Arial,sans-serif;
    background:#08122e;
    color:#fff;
}
a{text-decoration:none;color:inherit}
.container{
    max-width:1180px;
    margin:auto;
    padding:24px;
}
.topbar{
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:12px;
    margin-bottom:20px;
}
.brand{
    display:flex;
    align-items:center;
    gap:12px;
    font-size:28px;
    font-weight:800;
}
.brand-icon{font-size:44px}
.badge{
    background:#10b981;
    color:#fff;
    padding:10px 18px;
    border-radius:999px;
    font-size:14px;
    font-weight:800;
    box-shadow:0 10px 24px rgba(16,185,129,.18);
}
.hero{
    background:linear-gradient(135deg,#2d5bff,#7c3aed);
    border-radius:28px;
    padding:34px 28px;
    margin-bottom:22px;
    box-shadow:0 20px 50px rgba(0,0,0,.28);
}
.hero h1{
    margin:0 0 10px 0;
    font-size:56px;
    line-height:1.05;
}
.hero p{
    margin:0;
    font-size:20px;
    color:#ecebff;
}
.grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
    gap:18px;
    margin-bottom:22px;
}
.card{
    background:#0b1838;
    border-radius:22px;
    padding:22px;
    box-shadow:0 10px 30px rgba(0,0,0,.18);
    border:1px solid rgba(255,255,255,.04);
}
.card h3{
    margin:0 0 8px 0;
    font-size:20px;
}
.value{
    font-size:22px;
    font-weight:800;
    color:#f8fafc;
}
.toolbar{
    display:flex;
    flex-wrap:wrap;
    gap:12px;
    margin-bottom:22px;
}
.btn{
    border:none;
    border-radius:14px;
    padding:14px 22px;
    color:#fff;
    font-size:16px;
    font-weight:800;
    cursor:pointer;
    box-shadow:0 8px 20px rgba(0,0,0,.18);
}
.btn-blue{background:#2563eb}
.btn-purple{background:#7c3aed}
.btn-green{background:#059669}
.btn-red{background:#dc2626}
.section{
    margin-top:8px;
}
.section-title{
    font-size:30px;
    font-weight:800;
    margin:0 0 16px 0;
}
.log-wrap{
    background:#0b1838;
    border-radius:24px;
    padding:18px;
    box-shadow:0 10px 30px rgba(0,0,0,.18);
    border:1px solid rgba(255,255,255,.04);
}
.filter-row{
    display:flex;
    gap:10px;
    flex-wrap:wrap;
    margin-bottom:16px;
}
.filter-btn{
    padding:10px 14px;
    border-radius:999px;
    border:none;
    background:#1e293b;
    color:#fff;
    font-weight:700;
    cursor:pointer;
}
.filter-btn.active{
    background:#2563eb;
}
.log-list{
    display:grid;
    gap:14px;
}
.log-item{
    background:#1e293b;
    border-radius:18px;
    padding:18px;
    border-left:6px solid #334155;
}
.log-item.spam{border-left-color:#ef4444}
.log-item.temiz{border-left-color:#22c55e}
.log-head{
    display:flex;
    justify-content:space-between;
    gap:10px;
    flex-wrap:wrap;
    margin-bottom:10px;
}
.sender{
    font-size:18px;
    font-weight:800;
}
.status{
    font-size:13px;
    font-weight:800;
    padding:8px 12px;
    border-radius:999px;
}
.status.spam{
    background:rgba(239,68,68,.16);
    color:#fca5a5;
}
.status.temiz{
    background:rgba(34,197,94,.16);
    color:#86efac;
}
.meta{
    color:#94a3b8;
    font-size:13px;
    margin-bottom:10px;
}
.message{
    color:#e5e7eb;
    line-height:1.6;
    margin-bottom:12px;
    word-break:break-word;
}
.feedback-row{
    display:flex;
    gap:10px;
    flex-wrap:wrap;
}
.feedback-btn{
    border:none;
    border-radius:12px;
    padding:10px 14px;
    font-weight:800;
    cursor:pointer;
    color:#fff;
}
.btn-correct{background:#16a34a}
.btn-wrong{background:#dc2626}
.feedback-note{
    margin-top:8px;
    font-size:13px;
    color:#93c5fd;
}
.empty{
    color:#94a3b8;
    text-align:center;
    padding:22px;
}
.copyright{
    margin-top:30px;
    padding:15px;
    text-align:center;
    font-size:12px;
    color:#64748b;
    border-top:1px solid rgba(255,255,255,0.05);
}
@media (max-width:700px){
    .container{padding:18px}
    .brand{font-size:24px}
    .brand-icon{font-size:40px}
    .hero{padding:28px 22px}
    .hero h1{font-size:38px}
    .hero p{font-size:16px}
}
</style>
</head>
<body>

<div class="container">

    <div class="topbar">
        <div class="brand">
            <span class="brand-icon">🛡️</span>
            <span>SpamShield Premium</span>
        </div>
        <div class="badge" id="licenseBadge">PRO USER</div>
    </div>

    <div class="hero">
        <h1>Hoş geldin, {{ username }}</h1>
        <p>Panel aktif. Kullanıcı, lisans ve canlı log yönetimini buradan yapabilirsin.</p>
    </div>

    <div class="grid">
        <div class="card">
            <h3>Toplam Kullanıcı</h3>
            <div class="value">1</div>
        </div>
        <div class="card">
            <h3>Kalan Gün</h3>
            <div class="value">{{ days_left }}</div>
        </div>
        <div class="card">
            <h3>Lisans Modu</h3>
            <div class="value" id="licenseType">{{ license_type|upper }}</div>
        </div>
        <div class="card">
            <h3>Lisans Kodu</h3>
            <div class="value">MASTER-KEY</div>
        </div>
    </div>

    <div class="toolbar">
        <button class="btn btn-green" onclick="window.location.href='/pricing'">🛒 Lisans Satın Al</button>
        <button class="btn btn-blue" onclick="window.location.href='/activate-license'">🔑 Lisans Aktifleştir</button>
        <button class="btn btn-purple" onclick="window.location.href='/admin-licenses'">📦 Lisans Havuzu</button>
        <button class="btn btn-red" onclick="window.location.href='/logout'">🚪 Çıkış</button>
    </div>

    <div class="section">
        <h2 class="section-title">📡 Canlı SMS Akışı</h2>

        <div class="log-wrap">
            <div class="filter-row">
                <button class="filter-btn active" onclick="setFilter('ALL', this)">Tümü</button>
                <button class="filter-btn" onclick="setFilter('SPAM', this)">Sadece SPAM</button>
                <button class="filter-btn" onclick="setFilter('TEMIZ', this)">Sadece TEMİZ</button>
            </div>

            <div id="liveLogs" class="log-list">
                <div class="empty">Yükleniyor...</div>
            </div>
        </div>
    </div>

    <div class="copyright">
        🛡 SpamShield © 2026 • Tüm hakları saklıdır • Premium Panel
    </div>
</div>

<script>
let currentFilter = "ALL";

function setLicenseBadge() {
    const type = (document.getElementById("licenseType").innerText || "").toUpperCase();
    const badge = document.getElementById("licenseBadge");

    if (type.includes("PRO")) {
        badge.innerText = "PRO USER";
        badge.style.background = "#10b981";
    } else if (type.includes("TRIAL")) {
        badge.innerText = "TRIAL USER";
        badge.style.background = "#f59e0b";
    } else {
        badge.innerText = "FREE USER";
        badge.style.background = "#64748b";
    }
}

function setFilter(type, btn){
    currentFilter = type;
    document.querySelectorAll(".filter-btn").forEach(x => x.classList.remove("active"));
    btn.classList.add("active");
    loadLogs();
}

async function sendFeedback(log, correct, button){
    try {
        const res = await fetch("/api/feedback", {
            method: "POST",
            headers: {"Content-Type":"application/json"},
            body: JSON.stringify({
                log: log,
                correct: correct
            })
        });

        const data = await res.json();

        if(data.status === "success"){
            const row = button.closest(".feedback-row");
            if(row){
                const oldNote = row.parentElement.querySelector(".feedback-note");
                if (!oldNote) {
                    row.insertAdjacentHTML("afterend", '<div class="feedback-note">Geri bildirim kaydedildi.</div>');
                }
                row.querySelectorAll("button").forEach(b => b.disabled = true);
            }
        } else {
            alert("Geri bildirim kaydedilemedi");
        }
    } catch (e) {
        alert("Feedback hatası");
    }
}

async function loadLogs(){
    try {
        let res = await fetch("/api/logs");
        let data = await res.json();

        let logs = data.logs || [];
        let container = document.getElementById("liveLogs");

        if(currentFilter === "SPAM"){
            logs = logs.filter(x => (x.status || "").toUpperCase() === "SPAM");
        } else if(currentFilter === "TEMIZ"){
            logs = logs.filter(x => (x.status || "").toUpperCase() === "TEMIZ");
        }

        if(!logs.length){
            container.innerHTML = '<div class="empty">Filtreye uygun kayıt bulunamadı.</div>';
            return;
        }

        let html = "";

        logs.forEach((log)=>{
            let statusText = (log.status || "").toUpperCase();
            let cls = statusText === "SPAM" ? "spam" : "temiz";

            html += `
            <div class="log-item ${cls}">
                <div class="log-head">
                    <div class="sender">${log.from || "BILINMEYEN"}</div>
                    <div class="status ${cls}">${statusText}</div>
                </div>
                <div class="meta">🕒 ${log.timestamp || "-"} &nbsp; | &nbsp; 📊 Skor: ${log.score ?? 0}</div>
                <div class="message">${log.message || ""}</div>
                <div class="feedback-row">
                    <button class="feedback-btn btn-correct" onclick='sendFeedback(${JSON.stringify(log)}, true, this)'>✓ Doğru</button>
                    <button class="feedback-btn btn-wrong" onclick='sendFeedback(${JSON.stringify(log)}, false, this)'>✗ Yanlış</button>
                </div>
            </div>
            `;
        });

        container.innerHTML = html;

    } catch(e){
        console.log("log hata:", e);
        document.getElementById("liveLogs").innerHTML = '<div class="empty">Loglar yüklenemedi.</div>';
    }
}

setLicenseBadge();
loadLogs();
setInterval(loadLogs, 3000);
</script>

</body>
</html>
