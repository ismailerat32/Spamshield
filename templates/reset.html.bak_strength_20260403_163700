<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<title>Şifreyi Yenile</title>
<style>
body {
    background: linear-gradient(135deg, #0f172a, #0b1f5e, #1e3a8a);
    font-family: Arial, sans-serif;
    color: white;
    margin: 0;
    min-height: 100vh;
}
.wrap {
    max-width: 460px;
    margin: 60px auto;
    padding: 24px;
}
.card {
    background: rgba(3, 15, 45, 0.95);
    padding: 28px;
    border-radius: 24px;
    box-shadow: 0 10px 30px rgba(0,0,0,.25);
}
h1 {
    margin: 0 0 24px;
    font-size: 38px;
    line-height: 1.15;
}
label {
    display: block;
    margin: 16px 0 8px;
    font-size: 15px;
    color: #cbd5e1;
}
input {
    width: 100%;
    box-sizing: border-box;
    padding: 16px;
    border-radius: 18px;
    border: 1px solid rgba(255,255,255,.08);
    background: #020b2a;
    color: white;
    font-size: 16px;
    outline: none;
}
button {
    width: 100%;
    margin-top: 18px;
    padding: 16px;
    border: 0;
    border-radius: 18px;
    background: #1db446;
    color: white;
    font-size: 18px;
    font-weight: bold;
}
.msg-ok {
    background: rgba(16, 185, 129, .18);
    border: 1px solid rgba(16, 185, 129, .35);
    color: #d1fae5;
    padding: 16px;
    border-radius: 18px;
    margin-bottom: 18px;
}
.msg-err {
    background: rgba(239, 68, 68, .14);
    border: 1px solid rgba(239, 68, 68, .35);
    color: #fee2e2;
    padding: 16px;
    border-radius: 18px;
    margin-bottom: 18px;
}
.helper {
    margin-top: 10px;
    color: #93c5fd;
    font-size: 14px;
}
.link {
    display: inline-block;
    margin-top: 18px;
    color: #bfdbfe;
    text-decoration: none;
    font-size: 16px;
}
.password-wrap {
    position: relative;
}
.password-wrap input {
    padding-right: 52px;
}
.toggle-btn {
    position: absolute;
    right: 10px;
    top: 50%;
    transform: translateY(-50%);
    background: transparent;
    border: 0;
    color: #cbd5e1;
    font-size: 14px;
    cursor: pointer;
    width: auto;
    margin: 0;
    padding: 6px 8px;
}
.success-actions {
    margin-top: 16px;
}
.success-actions a {
    display: inline-block;
    padding: 12px 16px;
    border-radius: 14px;
    background: rgba(255,255,255,.08);
    color: white;
    text-decoration: none;
}
</style>
</head>
<body>
<div class="wrap">
    <div class="card">
        <h1>Şifreyi Yenile</h1>

        {% if error %}
        <div class="msg-err">{{ error }}</div>
        {% endif %}

        {% if success %}
        <div class="msg-ok">{{ success }}</div>
        <div class="success-actions">
            <a href="/login">Girişe dön</a>
        </div>
        {% endif %}

        <form method="POST" {% if success %}style="display:none;"{% endif %}>
            <label>Kullanıcı Adı</label>
            <input
                type="text"
                name="username"
                placeholder="Kullanıcı adını gir"
                value="{{ request.form.get('username', request.args.get('username', '')) }}"
                required
            >

            <label>Sıfırlama Kodu</label>
            <input
                type="text"
                name="code"
                placeholder="Sıfırlama kodunu gir"
                value="{{ request.form.get('code', request.args.get('code', '')) }}"
                required
            >

            <label>Yeni Şifre</label>
            <div class="password-wrap">
                <input
                    type="password"
                    name="password"
                    id="password"
                    placeholder="Yeni şifreni gir"
                    required
                    autofocus
                >
                <button type="button" class="toggle-btn" onclick="togglePassword()">Göster</button>
            </div>

            <div class="helper">Yeni şifreni girdikten sonra tek seferde kaydet.</div>

            <button type="submit">Şifreyi Güncelle</button>
        </form>

        <a class="link" href="/forgot-password">Yeni kod oluştur</a>
    </div>
</div>

<script>
function togglePassword() {
    const input = document.getElementById("password");
    const btn = document.querySelector(".toggle-btn");
    if (!input || !btn) return;

    if (input.type === "password") {
        input.type = "text";
        btn.textContent = "Gizle";
    } else {
        input.type = "password";
        btn.textContent = "Göster";
    }
}
</script>
</body>
</html>
